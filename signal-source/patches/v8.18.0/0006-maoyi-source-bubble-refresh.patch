diff --git a/ts/test-node/maoyi/sourceBubbleRefreshContract_test.node.ts b/ts/test-node/maoyi/sourceBubbleRefreshContract_test.node.ts
new file mode 100644
index 0000000..7f10cf1
--- /dev/null
+++ b/ts/test-node/maoyi/sourceBubbleRefreshContract_test.node.ts
@@ -0,0 +1,74 @@
+// Copyright 2026 Signal Messenger, LLC
+// SPDX-License-Identifier: AGPL-3.0-only
+
+import assert from 'node:assert/strict';
+import { readFileSync } from 'node:fs';
+
+function source(relativeUrl: string): string {
+  return readFileSync(new URL(relativeUrl, import.meta.url), 'utf8');
+}
+
+describe('Maoyi source bubble refresh contract', () => {
+  const message = source('../../components/conversation/Message.dom.tsx');
+  const timelineItem = source(
+    '../../components/conversation/TimelineItem.dom.tsx'
+  );
+  const smartTimelineItem = source(
+    '../../state/smart/TimelineItem.preload.tsx'
+  );
+  const rendererBridge = source('../../maoyi/messageBridge.preload.ts');
+  const styles = source('../../../stylesheets/_modules.scss');
+
+  it('renders the native refresh button beside the final translated character', () => {
+    const start = message.indexOf('public renderMaoyiTranslationRefresh()');
+    const end = message.indexOf('#shouldShowActionButton()', start);
+    assert.notEqual(start, -1);
+    assert.notEqual(end, -1);
+    const method = message.slice(start, end);
+    assert.match(method, /if \(!onMaoyiTranslationRefresh\)/);
+    assert.match(method, /<button[\s\S]*?>[\s\S]*?↻[\s\S]*?<\/button>/);
+    assert.match(
+      message,
+      /const characters = Array\.from\(maoyiTranslationText\)[\s\S]*?const lastCharacter = characters\.pop\(\) \?\? ''[\s\S]*?module-message__maoyi-translation-tail[\s\S]*?renderMaoyiTranslationRefresh\(\)/
+    );
+    assert.doesNotMatch(message, /renderMaoyiTranslationFooter/);
+    assert.match(
+      styles,
+      /\.module-message__maoyi-translation-tail[\s\S]*?display: inline-flex;[\s\S]*?white-space: nowrap;/
+    );
+    assert.match(
+      styles,
+      /\.module-message__maoyi-translation-refresh[\s\S]*?margin: 0 0 0 3px;/
+    );
+  });
+
+  it('threads only a canonical projection callback through smart and native timeline items', () => {
+    assert.match(
+      smartTimelineItem,
+      /requestMaoyiTranslationRefresh\(maoyiMessageProjection\)/
+    );
+    assert.match(
+      smartTimelineItem,
+      /maoyiMessageProjection \? onMaoyiTranslationRefresh : undefined/
+    );
+    assert.match(
+      timelineItem,
+      /onMaoyiTranslationRefresh=\{onMaoyiTranslationRefresh\}/
+    );
+  });
+
+  it('uses the authenticated bridge path without restoring a DOM scanner', () => {
+    for (const value of [
+      message,
+      timelineItem,
+      smartTimelineItem,
+      rendererBridge,
+    ]) {
+      assert.doesNotMatch(value, /MutationObserver|querySelectorAll\(/);
+    }
+    assert.match(
+      rendererBridge,
+      /type: 'translation\.refresh\.request'[\s\S]*?requestId: randomUUID\(\)/
+    );
+  });
+});
