+
+class FakeControlBridge {
+  public authenticated = true;
+  public readonly sent: Array<MaoyiControlEvent> = [];
+  readonly #commandHandlers = new Set<
+    (command: MaoyiControlCommand) => void
+  >();
+  readonly #transportHandlers = new Set<(authenticated: boolean) => void>();
+
+  public onCommand(
+    handler: (command: MaoyiControlCommand) => void
+  ): () => void {
+    this.#commandHandlers.add(handler);
+    return () => this.#commandHandlers.delete(handler);
+  }
+
+  public onTransportState(
+    handler: (authenticated: boolean) => void
+  ): () => void {
+    this.#transportHandlers.add(handler);
+    handler(this.authenticated);
+    return () => this.#transportHandlers.delete(handler);
+  }
+
+  public send(event: MaoyiControlEvent): boolean {
+    if (!this.authenticated) {
+      return false;
+    }
+    this.sent.push(event);
+    return true;
+  }
+
+  public emitCommand(command: MaoyiControlCommand): void {
+    for (const handler of this.#commandHandlers) {
+      handler(command);
+    }
+  }
+
+  public setAuthenticated(authenticated: boolean): void {
+    this.authenticated = authenticated;
+    for (const handler of this.#transportHandlers) {
+      handler(authenticated);
+    }
+  }
