@@ -0,0 +1,140 @@
+// Copyright 2026 Signal Messenger, LLC
+// SPDX-License-Identifier: AGPL-3.0-only
+
+import assert from 'node:assert/strict';
+
+import {
+  createMaoyiVisibleProjectionSignature,
+  createMaoyiVisibleMessageBatches,
+  maoyiVisibleBatchByteLimit,
+  maoyiVisibleBatchItemLimit,
+  maoyiVisibleBatchJsonBytes,
+} from '../../maoyi/messageBatching.std.ts';
+import {
+  projectMaoyiMessage,
+  type MaoyiMessageProjection,
+} from '../../maoyi/messageProjection.std.ts';
+
+const conversationId = '22222222-2222-4222-8222-222222222222';
+
+function projection(index: number): MaoyiMessageProjection {
+  const value = projectMaoyiMessage({
+    id: `33333333-3333-4333-8333-${index.toString().padStart(12, '0')}`,
+    conversationId,
+    text: `English visible message ${index}`,
+    direction: 'incoming',
+    timestamp: 1_800_000_000_000 + index,
+  });
+  assert.ok(value);
+  return value;
+}
+
+describe('Maoyi visible message batching', () => {
+  it('keeps every batch within the item and byte limits', () => {
+    const messages = Array.from({ length: 205 }, (_, index) =>
+      projection(index)
+    );
+    const batches = createMaoyiVisibleMessageBatches(
+      conversationId,
+      messages
+    );
+
+    assert.deepEqual(
+      batches.map(batch => batch.length),
+      [100, 100, 5]
+    );
+    for (const batch of batches) {
+      assert.ok(batch.length <= maoyiVisibleBatchItemLimit);
+      assert.ok(
+        maoyiVisibleBatchJsonBytes(conversationId, batch) <=
+          maoyiVisibleBatchByteLimit
+      );
+    }
+  });
+
+  it('deduplicates message IDs, drops cross-conversation items, and emits an empty snapshot', () => {
+    const first = {
+      ...projection(1),
+      messageId: 'abcdefab-cdef-4abc-8def-abcdefabcdef',
+    };
+    const caseEquivalent = {
+      ...first,
+      messageId: first.messageId.toUpperCase(),
+    };
+    const wrongConversation = {
+      ...projection(2),
+      conversationId: '44444444-4444-4444-8444-444444444444',
+    };
+    assert.deepEqual(
+      createMaoyiVisibleMessageBatches(conversationId, [
+        first,
+        first,
+        caseEquivalent,
+        wrongConversation,
+      ]),
+      [[first]]
+    );
+    assert.deepEqual(createMaoyiVisibleMessageBatches(conversationId, []), [
+      [],
+    ]);
+  });
+
+  it('counts 100 long messages in one linear byte-measurement pass', () => {
+    const messages = Array.from({ length: 100 }, (_, index) => {
+      const value = projectMaoyiMessage({
+        id: `abcdefab-cdef-4abc-8def-${index.toString(16).padStart(12, '0')}`,
+        conversationId,
+        text: `A${index.toString().padStart(4, '0')}${'b'.repeat(3_995)}`,
+        direction: 'incoming',
+        timestamp: 1_800_000_000_000 + index,
+      });
+      assert.ok(value);
+      return value;
+    });
+    let byteMeasurementCount = 0;
+    const batches = createMaoyiVisibleMessageBatches(
+      conversationId,
+      messages,
+      value => {
+        byteMeasurementCount += 1;
+        return new TextEncoder().encode(JSON.stringify(value)).byteLength;
+      }
+    );
+
+    assert.equal(byteMeasurementCount, messages.length + 1);
+    assert.deepEqual(
+      batches.map(batch => batch.length),
+      [100]
+    );
+    assert.equal(batches.flat().length, messages.length);
+    for (const batch of batches) {
+      assert.ok(
+        maoyiVisibleBatchJsonBytes(conversationId, batch) <=
+          maoyiVisibleBatchByteLimit
+      );
+    }
+  });
+
+  it('changes the exact projection signature on same-ID source edits and hash collisions', () => {
+    const original = projection(1);
+    const edited = {
+      ...original,
+      sourceText: 'Edited English source',
+    };
+    const sameHashCollision = {
+      ...original,
+      sourceHash: original.sourceHash,
+      sourceText: 'Collision English source',
+    };
+    assert.notEqual(
+      createMaoyiVisibleProjectionSignature(conversationId, [original]),
+      createMaoyiVisibleProjectionSignature(conversationId, [edited])
+    );
+    assert.notEqual(
+      createMaoyiVisibleProjectionSignature(conversationId, [original]),
+      createMaoyiVisibleProjectionSignature(conversationId, [
+        sameHashCollision,
+      ])
+    );
+  });
+});
