+      ipc.handler(event, {
+        type: 'conversation.changed',
+        conversationId: otherConversationId,
+      }),
+      true
+    );
+    assert.equal(
+      ipc.handler(event, {
+        type: 'message.visibleBatch',
+        requestId: localSnapshot.requestId,
+        conversationId: otherConversationId,
+        messages: [],
+      }),
+      true
+    );
+
+    bridge.stop();
+  });
+});
