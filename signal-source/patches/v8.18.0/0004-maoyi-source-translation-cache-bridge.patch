diff --git a/ts/maoyi/messageProjection.std.ts b/ts/maoyi/messageProjection.std.ts
new file mode 100644
index 0000000000000000000000000000000000000000..dc801c4e4423bd14fcc49101f47f3ef38ec1a62e
--- /dev/null
+++ b/ts/maoyi/messageProjection.std.ts
@@ -0,0 +1,123 @@
+// Copyright 2026 Signal Messenger, LLC
+// SPDX-License-Identifier: AGPL-3.0-only
+
+export const maoyiMaximumSourceTextLength = 4_000;
+
+export type MaoyiMessageProjectionInput = Readonly<{
+  id: string;
+  conversationId: string;
+  text?: string;
+  direction: 'incoming' | 'outgoing';
+  timestamp: number;
+  attachments?: ReadonlyArray<unknown>;
+  textAttachment?: unknown;
+  attachmentDroppedDueToSize?: boolean;
+  contact?: unknown;
+  deletedForEveryone?: boolean;
+  giftBadge?: unknown;
+  isSticker?: boolean;
+  isTapToView?: boolean;
+  payment?: unknown;
+  poll?: unknown;
+  storyReplyContext?: unknown;
+}>;
+
+export type MaoyiMessageProjection = Readonly<{
+  conversationId: string;
+  messageId: string;
+  sourceHash: string;
+  sourceText: string;
+  direction: 'incoming' | 'outgoing';
+  timestamp: number;
+}>;
+
+export type MaoyiTranslationResult = Readonly<{
+  conversationId: string;
+  messageId: string;
+  sourceHash: string;
+  sourceText: string;
+  translatedText: string;
+}>;
+
+export function normalizeMaoyiSourceText(text: string): string {
+  return text.replace(/\s+/g, ' ').trim();
+}
+
+// Keep this byte-for-byte compatible with the legacy renderer cache hash. Message and
+// conversation IDs remain the primary identity; this 32-bit hash is never sufficient
+// on its own.
+export function legacyMaoyiSourceHash(text: string): string {
+  let hash = 2166136261;
+  for (const char of normalizeMaoyiSourceText(text)) {
+    // The legacy implementation intentionally hashes UTF-16 code units this way.
+    // oxlint-disable-next-line no-bitwise
+    hash ^= char.charCodeAt(0);
+    hash = Math.imul(hash, 16777619);
+  }
+  // oxlint-disable-next-line no-bitwise
+  return (hash >>> 0).toString(36);
+}
+
+function hasExcludedMessagePayload(
+  message: MaoyiMessageProjectionInput
+): boolean {
+  return Boolean(
+    message.attachments?.length ||
+    message.textAttachment ||
+    message.attachmentDroppedDueToSize ||
+    message.contact ||
+    message.deletedForEveryone ||
+    message.giftBadge ||
+    message.isSticker ||
+    message.isTapToView ||
+    message.payment ||
+    message.poll ||
+    message.storyReplyContext
+  );
+}
+
+export function projectMaoyiMessage(
+  message: MaoyiMessageProjectionInput | undefined
+): MaoyiMessageProjection | undefined {
+  if (
+    !message ||
+    !message.id ||
+    !message.conversationId ||
+    !Number.isFinite(message.timestamp) ||
+    hasExcludedMessagePayload(message)
+  ) {
+    return undefined;
+  }
+
+  const sourceText = normalizeMaoyiSourceText(message.text ?? '');
+  if (
+    sourceText.length === 0 ||
+    sourceText.length > maoyiMaximumSourceTextLength ||
+    !/[A-Za-z]/.test(sourceText) ||
+    /[\u3400-\u9fff]/u.test(sourceText)
+  ) {
+    return undefined;
+  }
+
+  return {
+    conversationId: message.conversationId,
+    messageId: message.id,
+    sourceHash: legacyMaoyiSourceHash(sourceText),
+    sourceText,
+    direction: message.direction,
+    timestamp: message.timestamp,
+  };
+}
+
+export function maoyiTranslationMatchesProjection(
+  projection: MaoyiMessageProjection,
+  result: MaoyiTranslationResult
+): boolean {
+  return (
+    result.conversationId === projection.conversationId &&
+    result.messageId === projection.messageId &&
+    result.sourceText === projection.sourceText &&
+    result.sourceHash === projection.sourceHash &&
+    legacyMaoyiSourceHash(result.sourceText) === result.sourceHash
+  );
+}
diff --git a/ts/maoyi/translationRuntime.preload.ts b/ts/maoyi/translationRuntime.preload.ts
new file mode 100644
index 0000000000000000000000000000000000000000..18e3c58d64a0f6d70d7b26d571d2024de26d5df9
--- /dev/null
+++ b/ts/maoyi/translationRuntime.preload.ts
@@ -0,0 +1,239 @@
+// Copyright 2026 Signal Messenger, LLC
+// SPDX-License-Identifier: AGPL-3.0-only
+
+// The runtime is deliberately preload-scoped even before its IPC adapter is added.
+// oxlint-disable-next-line signal-desktop/enforce-file-suffix
+import { useCallback, useEffect, useSyncExternalStore } from 'react';
+
+import {
+  maoyiTranslationMatchesProjection,
+  legacyMaoyiSourceHash,
+  normalizeMaoyiSourceText,
+  type MaoyiMessageProjection,
+  type MaoyiTranslationResult,
+} from './messageProjection.std.ts';
+
+export const maoyiTranslationEntryLimit = 1_500;
+export const maoyiTranslationByteLimit = 15 * 1024 * 1024;
+
+const maximumIdentityLength = 256;
+const maximumTranslationLength = 30_000;
+
+type StoredMaoyiTranslation = MaoyiTranslationResult &
+  Readonly<{
+    estimatedBytes: number;
+  }>;
+
+type TranslationRuntimeStats = Readonly<{
+  entries: number;
+  estimatedBytes: number;
+}>;
+
+const translations = new Map<string, StoredMaoyiTranslation>();
+const subscribers = new Set<() => void>();
+let estimatedBytes = 0;
+
+function translationKey(conversationId: string, messageId: string): string {
+  return JSON.stringify([conversationId, messageId]);
+}
+
+function estimateTranslationBytes(result: MaoyiTranslationResult): number {
+  return (
+    128 +
+    (result.conversationId.length +
+      result.messageId.length +
+      result.sourceHash.length +
+      result.sourceText.length +
+      result.translatedText.length) *
+      2
+  );
+}
+
+function isBoundedIdentity(value: string): boolean {
+  return value.length > 0 && value.length <= maximumIdentityLength;
+}
+
+function normalizeTranslationResult(
+  result: MaoyiTranslationResult
+): StoredMaoyiTranslation | undefined {
+  if (
+    !isBoundedIdentity(result.conversationId) ||
+    !isBoundedIdentity(result.messageId) ||
+    !isBoundedIdentity(result.sourceHash) ||
+    result.sourceText !== normalizeMaoyiSourceText(result.sourceText) ||
+    legacyMaoyiSourceHash(result.sourceText) !== result.sourceHash
+  ) {
+    return undefined;
+  }
+
+  const translatedText = result.translatedText.trim();
+  if (
+    translatedText.length === 0 ||
+    translatedText.length > maximumTranslationLength
+  ) {
+    return undefined;
+  }
+
+  const normalized: MaoyiTranslationResult = {
+    conversationId: result.conversationId,
+    messageId: result.messageId,
+    sourceHash: result.sourceHash,
+    sourceText: result.sourceText,
+    translatedText,
+  };
+  return {
+    ...normalized,
+    estimatedBytes: estimateTranslationBytes(normalized),
+  };
+}
+
+function notifySubscribers(): void {
+  for (const subscriber of subscribers) {
+    try {
+      subscriber();
+    } catch {
+      // One React subscriber must not prevent the rest of a batch from rendering.
+    }
+  }
+}
+
+function touchTranslation(key: string): void {
+  const existing = translations.get(key);
+  if (!existing) {
+    return;
+  }
+  translations.delete(key);
+  translations.set(key, existing);
+}
+
+function trimTranslationCache(): boolean {
+  let changed = false;
+  while (
+    translations.size > maoyiTranslationEntryLimit ||
+    estimatedBytes > maoyiTranslationByteLimit
+  ) {
+    const oldest = translations.entries().next();
+    if (oldest.done) {
+      break;
+    }
+    const [key, value] = oldest.value;
+    translations.delete(key);
+    estimatedBytes = Math.max(0, estimatedBytes - value.estimatedBytes);
+    changed = true;
+  }
+  return changed;
+}
+
+export function applyMaoyiTranslationBatch(
+  results: ReadonlyArray<MaoyiTranslationResult>
+): number {
+  const changedKeys = new Set<string>();
+
+  for (const result of results) {
+    const normalized = normalizeTranslationResult(result);
+    if (!normalized) {
+      continue;
+    }
+
+    const key = translationKey(normalized.conversationId, normalized.messageId);
+    const existing = translations.get(key);
+    if (
+      existing &&
+      existing.sourceHash === normalized.sourceHash &&
+      existing.sourceText === normalized.sourceText &&
+      existing.translatedText === normalized.translatedText
+    ) {
+      touchTranslation(key);
+      continue;
+    }
+
+    if (existing) {
+      estimatedBytes = Math.max(0, estimatedBytes - existing.estimatedBytes);
+      translations.delete(key);
+    }
+    translations.set(key, normalized);
+    estimatedBytes += normalized.estimatedBytes;
+    changedKeys.add(key);
+  }
+
+  const evicted = trimTranslationCache();
+  if (changedKeys.size > 0 || evicted) {
+    notifySubscribers();
+  }
+  return changedKeys.size;
+}
+
+function peekMaoyiTranslation(
+  projection: MaoyiMessageProjection | undefined
+): string | undefined {
+  if (!projection) {
+    return undefined;
+  }
+  const result = translations.get(
+    translationKey(projection.conversationId, projection.messageId)
+  );
+  return result && maoyiTranslationMatchesProjection(projection, result)
+    ? result.translatedText
+    : undefined;
+}
+
+export function getMaoyiTranslation(
+  projection: MaoyiMessageProjection | undefined
+): string | undefined {
+  const translatedText = peekMaoyiTranslation(projection);
+  if (projection && translatedText) {
+    touchTranslation(
+      translationKey(projection.conversationId, projection.messageId)
+    );
+  }
+  return translatedText;
+}
+
+export function subscribeToMaoyiTranslations(
+  subscriber: () => void
+): () => void {
+  subscribers.add(subscriber);
+  return () => {
+    subscribers.delete(subscriber);
+  };
+}
+
+export function useMaoyiTranslation(
+  projection: MaoyiMessageProjection | undefined
+): string | undefined {
+  const getSnapshot = useCallback(
+    () => peekMaoyiTranslation(projection),
+    [projection]
+  );
+  const translatedText = useSyncExternalStore(
+    subscribeToMaoyiTranslations,
+    getSnapshot,
+    getSnapshot
+  );
+
+  useEffect(() => {
+    if (projection && translatedText) {
+      touchTranslation(
+        translationKey(projection.conversationId, projection.messageId)
+      );
+    }
+  }, [projection, translatedText]);
+
+  return translatedText;
+}
+
+export function clearMaoyiTranslationRuntime(): void {
+  if (translations.size === 0) {
+    return;
+  }
+  translations.clear();
+  estimatedBytes = 0;
+  notifySubscribers();
+}
+
+export function getMaoyiTranslationRuntimeStats(): TranslationRuntimeStats {
+  return {
+    entries: translations.size,
+    estimatedBytes,
+  };
+}
