+// Copyright 2026 Signal Messenger, LLC
+// SPDX-License-Identifier: AGPL-3.0-only
+
+import assert from 'node:assert/strict';
+
+import {
+  maoyiMaximumSourceTextLength,
+  maoyiTranslationMatchesProjection,
+  legacyMaoyiSourceHash,
+  normalizeMaoyiSourceText,
+  projectMaoyiMessage,
+  type MaoyiMessageProjectionInput,
+} from '../../maoyi/messageProjection.std.ts';
+
+function message(
+  overrides: Partial<MaoyiMessageProjectionInput> = {}
+): MaoyiMessageProjectionInput {
+  return {
+    id: 'message-1',
+    conversationId: 'conversation-1',
+    text: 'Hello world',
+    direction: 'incoming',
+    timestamp: 1_800_000_000_000,
+    ...overrides,
+  };
+}
+
+describe('Maoyi message projection', () => {
+  it('normalizes and hashes exactly like the legacy renderer cache', () => {
+    assert.equal(
+      normalizeMaoyiSourceText('  Hello\n\tworld  '),
+      'Hello world'
+    );
+    assert.equal(legacyMaoyiSourceHash('  Hello\n\tworld  '), 'os091j');
+    assert.equal(legacyMaoyiSourceHash('Hello world'), 'os091j');
+  });
+
+  it('projects a stable identity for an ordinary English body', () => {
+    assert.deepEqual(projectMaoyiMessage(message()), {
+      conversationId: 'conversation-1',
+      messageId: 'message-1',
+      sourceHash: 'os091j',
+      sourceText: 'Hello world',
+      direction: 'incoming',
+      timestamp: 1_800_000_000_000,
+    });
+  });
+
+  it('excludes non-English, oversized, attachment, and special bubbles', () => {
+    assert.equal(projectMaoyiMessage(message({ text: '你好' })), undefined);
+    assert.equal(
+      projectMaoyiMessage(message({ text: 'Hello 你好' })),
+      undefined
+    );
+    assert.equal(
+      projectMaoyiMessage(
+        message({ text: `A${'b'.repeat(maoyiMaximumSourceTextLength)}` })
+      ),
+      undefined
+    );
+
+    const excluded: ReadonlyArray<Partial<MaoyiMessageProjectionInput>> = [
+      { attachments: [{}] },
+      { textAttachment: {} },
+      { attachmentDroppedDueToSize: true },
+      { contact: {} },
+      { deletedForEveryone: true },
+      { giftBadge: {} },
+      { isSticker: true },
+      { isTapToView: true },
+      { payment: {} },
+      { poll: {} },
+      { storyReplyContext: {} },
+    ];
+    for (const payload of excluded) {
+      assert.equal(projectMaoyiMessage(message(payload)), undefined);
+    }
+  });
+
+  it('requires exact message, conversation, source text, and hash matches', () => {
+    const projection = projectMaoyiMessage(message());
+    assert.ok(projection);
+    const exact = {
+      conversationId: projection.conversationId,
+      messageId: projection.messageId,
+      sourceHash: projection.sourceHash,
+      sourceText: projection.sourceText,
+      translatedText: '你好，世界',
+    };
+    assert.equal(maoyiTranslationMatchesProjection(projection, exact), true);
+    assert.equal(
+      maoyiTranslationMatchesProjection(projection, {
+        ...exact,
+        sourceText: 'Hello  world',
+      }),
+      false
+    );
+    assert.equal(
+      maoyiTranslationMatchesProjection(projection, {
+        ...exact,
+        messageId: 'message-2',
+      }),
+      false
+    );
+    assert.equal(
+      maoyiTranslationMatchesProjection(projection, {
+        ...exact,
+        sourceHash: 'tampered',
+      }),
+      false
+    );
+  });
+});
diff --git a/ts/test-node/maoyi/rendererMessageBridge_test.preload.ts b/ts/test-node/maoyi/rendererMessageBridge_test.preload.ts
new file mode 100644
index 0000000000000000000000000000000000000000..cfafc040d8e0df48485e212e61abc03f22f523c0
--- /dev/null
+++ b/ts/test-node/maoyi/rendererMessageBridge_test.preload.ts
@@ -0,0 +1,405 @@
+// Copyright 2026 Signal Messenger, LLC
+// SPDX-License-Identifier: AGPL-3.0-only
+
+import assert from 'node:assert/strict';
+import type { IpcRendererEvent } from 'electron';
+
+import { createMaoyiRendererMessageBridge } from '../../maoyi/messageBridge.preload.ts';
+import {
+  projectMaoyiMessage,
+  type MaoyiMessageProjection,
+} from '../../maoyi/messageProjection.std.ts';
+import {
+  clearMaoyiTranslationRuntime,
+  getMaoyiTranslation,
+} from '../../maoyi/translationRuntime.preload.ts';
+import {
+  maoyiMessageCommandChannel,
+  maoyiMessageEventChannel,
+} from '../../maoyi/messageBridgeChannels.std.ts';
+
+const conversationId = '22222222-2222-4222-8222-222222222222';
+const otherConversationId = '44444444-4444-4444-8444-444444444444';
+const messageId = 'abcdefab-cdef-4abc-8def-abcdefabcdef';
+
+function projection(
+  overrides: Readonly<{
+    messageId?: string;
+    conversationId?: string;
+    text?: string;
+    timestamp?: number;
+  }> = {}
+): MaoyiMessageProjection {
+  const value = projectMaoyiMessage({
+    id: overrides.messageId ?? messageId,
+    conversationId: overrides.conversationId ?? conversationId,
+    text: overrides.text ?? 'Hello world',
+    direction: 'incoming',
+    timestamp: overrides.timestamp ?? 1_800_000_000_000,
+  });
+  assert.ok(value);
+  return value;
+}
+
+type InvocationBlocker = Readonly<{
+  type: string;
+  observed: Promise<void>;
+  markObserved: () => void;
+  wait: Promise<void>;
+  release: () => void;
+}>;
+
+function isVisibleBatch(value: unknown): value is Readonly<{
+  type: 'message.visibleBatch';
+  requestId: string;
+  conversationId: string;
+  messages: ReadonlyArray<MaoyiMessageProjection>;
+}> {
+  return (
+    typeof value === 'object' &&
+    value != null &&
+    'type' in value &&
+    value.type === 'message.visibleBatch' &&
+    'requestId' in value &&
+    typeof value.requestId === 'string' &&
+    'conversationId' in value &&
+    typeof value.conversationId === 'string' &&
+    'messages' in value &&
+    Array.isArray(value.messages)
+  );
+}
+
+class FakeRendererTransport {
+  public readonly invocations: Array<unknown> = [];
+  public listener:
+    | ((event: IpcRendererEvent, value: unknown) => void)
+    | undefined;
+  public blocker: InvocationBlocker | undefined;
+  public rejectedType: string | undefined;
+
+  public async invoke(channel: string, value: unknown): Promise<boolean> {
+    assert.equal(channel, maoyiMessageEventChannel);
+    this.invocations.push(value);
+    const blocker = this.blocker;
+    if (
+      blocker &&
+      typeof value === 'object' &&
+      value != null &&
+      'type' in value &&
+      value.type === blocker.type
+    ) {
+      blocker.markObserved();
+      await blocker.wait;
+      if (this.blocker === blocker) {
+        this.blocker = undefined;
+      }
+    }
+    if (
+      this.rejectedType &&
+      typeof value === 'object' &&
+      value != null &&
+      'type' in value &&
+      value.type === this.rejectedType
+    ) {
+      this.rejectedType = undefined;
+      return false;
+    }
+    return true;
+  }
+
+  public blockNext(type: string): InvocationBlocker {
+    let markObserved: (() => void) | undefined;
+    let release: (() => void) | undefined;
+    const blocker: InvocationBlocker = {
+      type,
+      observed: new Promise<void>(resolve => {
+        markObserved = resolve;
+      }),
+      markObserved: () => markObserved?.(),
+      wait: new Promise<void>(resolve => {
+        release = resolve;
+      }),
+      release: () => release?.(),
+    };
+    this.blocker = blocker;
+    return blocker;
+  }
+
+  public rejectNext(type: string): void {
+    this.rejectedType = type;
+  }
+
+  public on(
+    channel: string,
+    listener: (event: IpcRendererEvent, value: unknown) => void
+  ): void {
+    assert.equal(channel, maoyiMessageCommandChannel);
+    this.listener = listener;
+  }
+
+  public off(
+    channel: string,
+    listener: (event: IpcRendererEvent, value: unknown) => void
+  ): void {
+    assert.equal(channel, maoyiMessageCommandChannel);
+    if (this.listener === listener) {
+      this.listener = undefined;
+    }
+  }
+
+  public emit(value: unknown): void {
+    this.listener?.({} as IpcRendererEvent, value);
+  }
+}
+
+describe('Maoyi renderer message bridge', () => {
+  beforeEach(() => clearMaoyiTranslationRuntime());
+  afterEach(() => clearMaoyiTranslationRuntime());
+
+  it('applies only an exact one-time result and clears on the main-process gate', async () => {
+    const transport = new FakeRendererTransport();
+    const bridge = createMaoyiRendererMessageBridge(transport);
+    const value = projection();
+
+    await bridge.publishVisibleMessages(conversationId, [value]);
+    const visible = transport.invocations.find(
+      item =>
+        typeof item === 'object' &&
+        item != null &&
+        'type' in item &&
+        item.type === 'message.visibleBatch'
+    );
+    assert.ok(
+      typeof visible === 'object' && visible != null && 'requestId' in visible
+    );
+    const requestId = visible.requestId;
+    assert.equal(typeof requestId, 'string');
+
+    transport.emit({
+      type: 'translation.cacheResultBatch',
+      requestId,
+      conversationId,
+      results: [
+        {
+          conversationId,
+          messageId,
+          sourceHash: value.sourceHash,
+          sourceText: value.sourceText,
+          translatedText: '译文',
+        },
+      ],
+    });
+    assert.equal(getMaoyiTranslation(value), '译文');
+
+    transport.emit({
+      type: 'translation.cacheResultBatch',
+      requestId,
+      conversationId,
+      results: [
+        {
+          conversationId,
+          messageId,
+          sourceHash: value.sourceHash,
+          sourceText: value.sourceText,
+          translatedText: 'replayed translation',
+        },
+      ],
+    });
+    assert.equal(getMaoyiTranslation(value), '译文');
+
+    transport.emit({ type: 'translation.runtime.clear' });
+    assert.equal(getMaoyiTranslation(value), undefined);
+    bridge.stop();
+  });
+
+  it('rejects a result batch when any returned source identity is mismatched', async () => {
+    const transport = new FakeRendererTransport();
+    const bridge = createMaoyiRendererMessageBridge(transport);
+    const value = projection();
+
+    await bridge.publishVisibleMessages(conversationId, [value]);
+    const visible = transport.invocations.at(-1);
+    assert.ok(
+      typeof visible === 'object' &&
+        visible != null &&
+        'requestId' in visible &&
+        typeof visible.requestId === 'string'
+    );
+    transport.emit({
+      type: 'translation.cacheResultBatch',
+      requestId: visible.requestId,
+      conversationId,
+      results: [
+        {
+          conversationId,
+          messageId,
+          sourceHash: value.sourceHash,
+          sourceText: 'Edited source text',
+          translatedText: 'must not render',
+        },
+      ],
+    });
+    assert.equal(getMaoyiTranslation(value), undefined);
+    bridge.stop();
+  });
+
+  it('rejects message UUID duplicates that differ only by letter case', async () => {
+    const transport = new FakeRendererTransport();
+    const bridge = createMaoyiRendererMessageBridge(transport);
+    const value = projection();
+
+    await bridge.publishVisibleMessages(conversationId, [value]);
+    const visible = transport.invocations.at(-1);
+    assert.ok(
+      typeof visible === 'object' &&
+        visible != null &&
+        'requestId' in visible &&
+        typeof visible.requestId === 'string'
+    );
+    const invocationCount = transport.invocations.length;
+    transport.emit({
+      type: 'translation.cacheResultBatch',
+      requestId: visible.requestId,
+      conversationId,
+      results: [
+        {
+          conversationId,
+          messageId,
+          sourceHash: value.sourceHash,
+          sourceText: value.sourceText,
+          translatedText: 'first translation',
+        },
+        {
+          conversationId,
+          messageId: messageId.toUpperCase(),
+          sourceHash: value.sourceHash,
+          sourceText: value.sourceText,
+          translatedText: 'second translation',
+        },
+      ],
+    });
+    assert.equal(getMaoyiTranslation(value), undefined);
+    assert.equal(transport.invocations.length, invocationCount);
+    bridge.stop();
+  });
+
+  it('invalidates an old result when the same visible message body is edited', async () => {
+    const transport = new FakeRendererTransport();
+    const bridge = createMaoyiRendererMessageBridge(transport);
+    const original = projection();
+    const edited = projection({ text: 'Edited English body' });
+
+    await bridge.publishVisibleMessages(conversationId, [original]);
+    const originalVisible = transport.invocations.find(isVisibleBatch);
+    assert.ok(originalVisible);
+    await bridge.publishVisibleMessages(conversationId, [edited]);
+    const visibleBatches = transport.invocations.filter(isVisibleBatch);
+    const editedVisible = visibleBatches.at(-1);
+    assert.ok(editedVisible);
+    assert.notEqual(editedVisible.requestId, originalVisible.requestId);
+    assert.equal(editedVisible.messages[0]?.sourceText, edited.sourceText);
+
+    transport.emit({
+      type: 'translation.cacheResultBatch',
+      requestId: originalVisible.requestId,
+      conversationId,
+      results: [
+        {
+          conversationId,
+          messageId,
+          sourceHash: original.sourceHash,
+          sourceText: original.sourceText,
+          translatedText: 'stale translation',
+        },
+      ],
+    });
+    assert.equal(getMaoyiTranslation(original), undefined);
+    assert.equal(getMaoyiTranslation(edited), undefined);
+
+    transport.emit({
+      type: 'translation.cacheResultBatch',
+      requestId: editedVisible.requestId,
+      conversationId,
+      results: [
+        {
+          conversationId,
+          messageId,
+          sourceHash: edited.sourceHash,
+          sourceText: edited.sourceText,
+          translatedText: 'fresh translation',
+        },
+      ],
+    });
+    assert.equal(getMaoyiTranslation(edited), 'fresh translation');
+    bridge.stop();
+  });
+
+  it('re-reads a queued snapshot after A/B switch and stops remaining A batches', async () => {
+    const transport = new FakeRendererTransport();
+    const bridge = createMaoyiRendererMessageBridge(transport);
+    const messagesA = Array.from({ length: 101 }, (_, index) =>
+      projection({
+        messageId: `abcdefab-cdef-4abc-8def-${index
+          .toString(16)
+          .padStart(12, '0')}`,
+        text: `English A message ${index}`,
+        timestamp: 1_800_000_000_000 + index,
+      })
+    );
+    const messageB = projection({
+      conversationId: otherConversationId,
+      text: 'English B message',
+    });
+    const removeProviderA = bridge.setSnapshotProvider(() => ({
+      conversationId,
+      messages: messagesA,
+    }));
+    const blocker = transport.blockNext('message.visibleBatch');
+    const publishA = bridge.publishVisibleMessages(conversationId, messagesA);
+    await blocker.observed;
+
+    const forcedRequestId = '66666666-6666-4666-8666-666666666666';
+    transport.emit({
+      type: 'message.snapshot.request',
+      requestId: forcedRequestId,
+    });
+    removeProviderA();
+    bridge.setSnapshotProvider(() => ({
+      conversationId: otherConversationId,
+      messages: [messageB],
+    }));
+    const publishB = bridge.publishVisibleMessages(otherConversationId, [
+      messageB,
+    ]);
+    blocker.release();
+    await Promise.all([publishA, publishB]);
+
+    const visibleBatches = transport.invocations.filter(isVisibleBatch);
+    assert.equal(
+      visibleBatches.filter(item => item.conversationId === conversationId)
+        .length,
+      1
+    );
+    const forcedBatch = visibleBatches.find(
+      item => item.requestId === forcedRequestId
+    );
+    assert.ok(forcedBatch);
+    assert.equal(forcedBatch.conversationId, otherConversationId);
+    assert.equal(forcedBatch.messages[0]?.sourceText, messageB.sourceText);
+    bridge.stop();
+  });
+
+  it('retries the same visible signature after transport rejection', async () => {
+    const transport = new FakeRendererTransport();
+    const bridge = createMaoyiRendererMessageBridge(transport);
+    const value = projection();
+    transport.rejectNext('message.visibleBatch');
+
+    await bridge.publishVisibleMessages(conversationId, [value]);
+    await bridge.publishVisibleMessages(conversationId, [value]);
+    const visibleBatches = transport.invocations.filter(isVisibleBatch);
+    assert.equal(visibleBatches.length, 2);
+    assert.notEqual(visibleBatches[0]?.requestId, visibleBatches[1]?.requestId);
+    bridge.stop();
+  });
+});
diff --git a/ts/test-node/maoyi/translationRuntime_test.preload.ts b/ts/test-node/maoyi/translationRuntime_test.preload.ts
new file mode 100644
index 0000000000000000000000000000000000000000..5f2d5306675669ba659e5c6e7cc043f156967410
--- /dev/null
+++ b/ts/test-node/maoyi/translationRuntime_test.preload.ts
@@ -0,0 +1,158 @@
+// Copyright 2026 Signal Messenger, LLC
+// SPDX-License-Identifier: AGPL-3.0-only
+
+import assert from 'node:assert/strict';
+
+import {
+  legacyMaoyiSourceHash,
+  projectMaoyiMessage,
+  type MaoyiMessageProjection,
+  type MaoyiTranslationResult,
+} from '../../maoyi/messageProjection.std.ts';
+import {
+  applyMaoyiTranslationBatch,
+  clearMaoyiTranslationRuntime,
+  maoyiTranslationByteLimit,
+  maoyiTranslationEntryLimit,
+  getMaoyiTranslation,
+  getMaoyiTranslationRuntimeStats,
+  subscribeToMaoyiTranslations,
+} from '../../maoyi/translationRuntime.preload.ts';
+
+function projection(
+  messageId: string,
+  sourceText = `English message ${messageId}`,
+  conversationId = 'conversation-1'
+): MaoyiMessageProjection {
+  const value = projectMaoyiMessage({
+    id: messageId,
+    conversationId,
+    text: sourceText,
+    direction: 'incoming',
+    timestamp: 1_800_000_000_000,
+  });
+  assert.ok(value);
+  return value;
+}
+
+function result(
+  value: MaoyiMessageProjection,
+  translatedText = `译文 ${value.messageId}`
+): MaoyiTranslationResult {
+  return {
+    conversationId: value.conversationId,
+    messageId: value.messageId,
+    sourceHash: value.sourceHash,
+    sourceText: value.sourceText,
+    translatedText,
+  };
+}
+
+describe('Maoyi translation runtime', () => {
+  beforeEach(() => {
+    clearMaoyiTranslationRuntime();
+  });
+
+  afterEach(() => {
+    clearMaoyiTranslationRuntime();
+  });
+
+  it('applies a whole batch before notifying subscribers once', () => {
+    const first = projection('message-1');
+    const second = projection('message-2');
+    let notifications = 0;
+    const unsubscribe = subscribeToMaoyiTranslations(() => {
+      notifications += 1;
+    });
+    try {
+      assert.equal(
+        applyMaoyiTranslationBatch([result(first), result(second)]),
+        2
+      );
+      assert.equal(notifications, 1);
+      assert.equal(getMaoyiTranslation(first), '译文 message-1');
+      assert.equal(getMaoyiTranslation(second), '译文 message-2');
+
+      assert.equal(
+        applyMaoyiTranslationBatch([result(first), result(second)]),
+        0
+      );
+      assert.equal(notifications, 1);
+    } finally {
+      unsubscribe();
+    }
+  });
+
+  it('isolates identical message IDs by conversation and rejects edited text', () => {
+    const firstConversation = projection('same-id', 'Original English text');
+    const secondConversation = projection(
+      'same-id',
+      'Other English text',
+      'conversation-2'
+    );
+    applyMaoyiTranslationBatch([
+      result(firstConversation, '第一段译文'),
+      result(secondConversation, '第二段译文'),
+    ]);
+
+    assert.equal(getMaoyiTranslation(firstConversation), '第一段译文');
+    assert.equal(getMaoyiTranslation(secondConversation), '第二段译文');
+    assert.equal(
+      getMaoyiTranslation(
+        projection('same-id', 'Edited English text', 'conversation-1')
+      ),
+      undefined
+    );
+  });
+
+  it('rejects non-canonical source text and tampered legacy hashes', () => {
+    const value = projection('message-1');
+    assert.equal(
+      applyMaoyiTranslationBatch([
+        { ...result(value), sourceText: 'English  message message-1' },
+        { ...result(value), sourceHash: 'tampered' },
+      ]),
+      0
+    );
+    assert.equal(getMaoyiTranslation(value), undefined);
+    assert.equal(legacyMaoyiSourceHash(value.sourceText), value.sourceHash);
+  });
+
+  it('evicts the least-recently-used entry at the 1500-entry limit', () => {
+    const projections = Array.from(
+      { length: maoyiTranslationEntryLimit },
+      (_, index) => projection(`message-${index}`)
+    );
+    applyMaoyiTranslationBatch(projections.map(value => result(value)));
+
+    // Reading an entry makes it the most recently used without notifying subscribers.
+    const first = projections[0];
+    const second = projections[1];
+    assert.ok(first);
+    assert.ok(second);
+    assert.equal(getMaoyiTranslation(first), '译文 message-0');
+    const newest = projection('message-newest');
+    applyMaoyiTranslationBatch([result(newest)]);
+
+    assert.equal(getMaoyiTranslation(first), '译文 message-0');
+    assert.equal(getMaoyiTranslation(second), undefined);
+    assert.equal(getMaoyiTranslation(newest), '译文 message-newest');
+    assert.equal(
+      getMaoyiTranslationRuntimeStats().entries,
+      maoyiTranslationEntryLimit
+    );
+  });
+
+  it('keeps the in-memory cache below the 15 MiB byte limit', () => {
+    const largeResults = Array.from({ length: 300 }, (_, index) => {
+      const value = projection(`large-${index}`);
+      return result(value, '中'.repeat(30_000));
+    });
+    applyMaoyiTranslationBatch(largeResults);
+
+    const stats = getMaoyiTranslationRuntimeStats();
+    assert.ok(stats.entries > 0);
+    assert.ok(stats.entries < largeResults.length);
+    assert.ok(stats.estimatedBytes <= maoyiTranslationByteLimit);
+  });
+});
diff --git a/ts/test-node/maoyi/translationSlot_test.node.ts b/ts/test-node/maoyi/translationSlot_test.node.ts
