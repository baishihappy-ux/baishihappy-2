+// Copyright 2026 Signal Messenger, LLC
+// SPDX-License-Identifier: AGPL-3.0-only
+
+import type { MessageLookupType } from '../state/ducks/conversations.preload.ts';
+import {
+  projectMaoyiMessage,
+  type MaoyiMessageProjection,
+} from './messageProjection.std.ts';
+
+export function projectMaoyiVisibleMessages(
+  conversationId: string,
+  messageIds: ReadonlyArray<string>,
+  messages: MessageLookupType
+): Array<MaoyiMessageProjection> {
+  const result: Array<MaoyiMessageProjection> = [];
+  const seen = new Set<string>();
+
+  for (const messageId of messageIds) {
+    if (seen.has(messageId)) {
+      continue;
+    }
+    seen.add(messageId);
+
+    const message = messages[messageId];
+    if (
+      !message ||
+      message.conversationId !== conversationId ||
+      (message.type !== 'incoming' && message.type !== 'outgoing') ||
+      !Number.isSafeInteger(message.timestamp) ||
+      message.timestamp < 0
+    ) {
+      continue;
+    }
+
+    const projection = projectMaoyiMessage({
+      id: message.id,
+      conversationId: message.conversationId,
+      text: message.body,
+      direction: message.type,
+      timestamp: message.timestamp,
+      attachments: message.attachments,
+      textAttachment: message.bodyAttachment,
+      contact: message.contact,
+      deletedForEveryone: message.deletedForEveryone,
+      giftBadge: message.giftBadge,
+      isSticker: Boolean(message.sticker),
+      isTapToView: Boolean(message.isViewOnce),
+      payment: message.payment,
+      poll: message.poll,
+      storyReplyContext: message.storyReplyContext,
+    });
+    if (projection) {
+      result.push(projection);
+    }
+  }
+
+  return result;
+}
