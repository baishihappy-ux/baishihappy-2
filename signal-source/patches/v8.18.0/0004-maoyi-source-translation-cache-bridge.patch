@@ -0,0 +1,438 @@
+// Copyright 2026 Signal Messenger, LLC
+// SPDX-License-Identifier: AGPL-3.0-only
+
+import { randomUUID } from 'node:crypto';
+import {
+  ipcMain,
+  type BrowserWindow,
+  type IpcMain,
+  type IpcMainInvokeEvent,
+} from 'electron';
+
+import {
+  getMaoyiControlBridge,
+  type MaoyiControlBridge,
+} from './controlBridge.main.ts';
+import {
+  parseMaoyiMessageControlEvent,
+  type MaoyiControlCommand,
+} from './controlProtocol.node.ts';
+import {
+  getMaoyiWindowController,
+  type MaoyiWindowController,
+} from './windowController.main.ts';
+import {
+  maoyiMessageCommandChannel,
+  maoyiMessageEventChannel,
+  type MaoyiRendererCommand,
+} from '../../ts/maoyi/messageBridgeChannels.std.ts';
+
+const messageBridgeKey = Symbol.for('maoyi.signal.message-bridge.v1');
+
+export const maoyiRequestCorrelationLimit = 128;
+export const maoyiRequestCorrelationTtlMs = 30_000;
+
+type RequestState =
+  | 'snapshot-forwarded'
+  | 'awaiting-result'
+  | 'awaiting-ack'
+  | 'consumed';
+
+type RequestEntry = {
+  state: RequestState;
+  conversationId?: string;
+  surviveConversationChange?: boolean;
+  expiresAt: number;
+};
+
+export class MaoyiRequestLedger {
+  readonly #entries = new Map<string, RequestEntry>();
+  readonly #now: () => number;
+  readonly #limit: number;
+  readonly #ttlMs: number;
+
+  constructor(
+    now: () => number = Date.now,
+    limit = maoyiRequestCorrelationLimit,
+    ttlMs = maoyiRequestCorrelationTtlMs
+  ) {
+    this.#now = now;
+    this.#limit = limit;
+    this.#ttlMs = ttlMs;
+  }
+
+  #prune(): void {
+    const now = this.#now();
+    for (const [requestId, entry] of this.#entries) {
+      if (entry.expiresAt <= now) {
+        this.#entries.delete(requestId);
+      }
+    }
+  }
+
+  #makeRoom(): boolean {
+    this.#prune();
+    if (this.#entries.size < this.#limit) {
+      return true;
+    }
+    for (const [requestId, entry] of this.#entries) {
+      if (entry.state === 'consumed') {
+        this.#entries.delete(requestId);
+        return true;
+      }
+    }
+    return false;
+  }
+
+  beginSnapshot(requestId: string, surviveConversationChange = false): boolean {
+    this.#prune();
+    if (this.#entries.has(requestId) || !this.#makeRoom()) {
+      return false;
+    }
+    this.#entries.set(requestId, {
+      state: 'snapshot-forwarded',
+      surviveConversationChange,
+      expiresAt: this.#now() + this.#ttlMs,
+    });
+    return true;
+  }
+
+  beginVisible(requestId: string, conversationId: string): boolean {
+    this.#prune();
+    const existing = this.#entries.get(requestId);
+    if (existing) {
+      if (existing.state !== 'snapshot-forwarded') {
+        return false;
+      }
+      this.#entries.set(requestId, {
+        state: 'awaiting-result',
+        conversationId,
+        expiresAt: this.#now() + this.#ttlMs,
+      });
+      return true;
+    }
+    if (!this.#makeRoom()) {
+      return false;
+    }
+    this.#entries.set(requestId, {
+      state: 'awaiting-result',
+      conversationId,
+      expiresAt: this.#now() + this.#ttlMs,
+    });
+    return true;
+  }
+
+  acceptResult(requestId: string, conversationId: string): boolean {
+    this.#prune();
+    const existing = this.#entries.get(requestId);
+    if (
+      !existing ||
+      existing.state !== 'awaiting-result' ||
+      existing.conversationId !== conversationId
+    ) {
+      return false;
+    }
+    this.#entries.set(requestId, {
+      state: 'awaiting-ack',
+      conversationId,
+      expiresAt: this.#now() + this.#ttlMs,
+    });
+    return true;
+  }
+
+  acceptAck(requestId: string): boolean {
+    this.#prune();
+    const existing = this.#entries.get(requestId);
+    if (!existing || existing.state !== 'awaiting-ack') {
+      return false;
+    }
+    this.consume(requestId);
+    return true;
+  }
+
+  consume(requestId: string): void {
+    if (!this.#entries.has(requestId)) {
+      return;
+    }
+    this.#entries.set(requestId, {
+      state: 'consumed',
+      expiresAt: this.#now() + this.#ttlMs,
+    });
+  }
+
+  invalidateAll(): void {
+    for (const requestId of this.#entries.keys()) {
+      this.consume(requestId);
+    }
+  }
+
+  invalidateForConversationChange(): void {
+    for (const [requestId, entry] of this.#entries) {
+      if (
+        entry.state === 'snapshot-forwarded' &&
+        entry.surviveConversationChange
+      ) {
+        this.#entries.set(requestId, {
+          ...entry,
+          surviveConversationChange: false,
+        });
+      } else {
+        this.consume(requestId);
+      }
+    }
+  }
+
+  clear(): void {
+    this.#entries.clear();
+  }
+}
+
+export type MaoyiMessageBridge = Readonly<{
+  attachMainWindow: (window: BrowserWindow) => void;
+  stop: () => void;
+}>;
+
+type MaoyiIpcMain = Pick<IpcMain, 'handle' | 'removeHandler'>;
+
+export function getMaoyiMessageBridge(): MaoyiMessageBridge | undefined {
+  return Reflect.get(globalThis, messageBridgeKey) as
+    | MaoyiMessageBridge
+    | undefined;
+}
+
+export function startMaoyiMessageBridge(
+  bridgeArgument?: MaoyiControlBridge,
+  controllerArgument?: MaoyiWindowController,
+  ipcArgument: MaoyiIpcMain = ipcMain
+): MaoyiMessageBridge {
+  const existing = getMaoyiMessageBridge();
+  if (existing) {
+    return existing;
+  }
+
+  const controlBridge = bridgeArgument ?? getMaoyiControlBridge();
+  const windowController = controllerArgument ?? getMaoyiWindowController();
+  if (!controlBridge || !windowController) {
+    throw new Error('Maoyi message bridge dependencies are unavailable');
+  }
+
+  const requestLedger = new MaoyiRequestLedger();
+  let mainWindow: BrowserWindow | undefined;
+  let currentConversationId: string | undefined;
+  let transportAuthenticated = false;
+  let stopped = false;
+
+  const sendRendererCommand = (command: MaoyiRendererCommand): boolean => {
+    if (
+      !mainWindow ||
+      mainWindow.isDestroyed() ||
+      mainWindow.webContents.isDestroyed()
+    ) {
+      return false;
+    }
+    try {
+      mainWindow.webContents.send(maoyiMessageCommandChannel, command);
+      return true;
+    } catch {
+      return false;
+    }
+  };
+
+  const clearRendererRuntime = (): void => {
+    currentConversationId = undefined;
+    requestLedger.invalidateAll();
+    sendRendererCommand({ type: 'translation.runtime.clear' });
+  };
+
+  const canForward = (): boolean =>
+    Boolean(
+      !stopped &&
+      transportAuthenticated &&
+      mainWindow &&
+      !mainWindow.isDestroyed() &&
+      !mainWindow.webContents.isDestroyed() &&
+      mainWindow.isVisible() &&
+      windowController.canExposeWindows()
+    );
+
+  const handleRendererEvent = (
+    event: IpcMainInvokeEvent,
+    value: unknown
+  ): boolean => {
+    if (!mainWindow || event.sender !== mainWindow.webContents) {
+      return false;
+    }
+    if (!canForward()) {
+      clearRendererRuntime();
+      return false;
+    }
+
+    const parsed = parseMaoyiMessageControlEvent(value);
+    if (!parsed) {
+      return false;
+    }
+
+    switch (parsed.type) {
+      case 'conversation.changed': {
+        if (currentConversationId !== parsed.conversationId) {
+          requestLedger.invalidateForConversationChange();
+        }
+        currentConversationId = parsed.conversationId;
+        if (!controlBridge.send(parsed)) {
+          currentConversationId = undefined;
+          return false;
+        }
+        return true;
+      }
+      case 'message.visibleBatch': {
+        if (
+          currentConversationId !== parsed.conversationId ||
+          !requestLedger.beginVisible(parsed.requestId, parsed.conversationId)
+        ) {
+          return false;
+        }
+        if (!controlBridge.send(parsed)) {
+          requestLedger.consume(parsed.requestId);
+          return false;
+        }
+        return true;
+      }
+      case 'translation.cacheResultApplied': {
+        if (!requestLedger.acceptAck(parsed.requestId)) {
+          return false;
+        }
+        return controlBridge.send(parsed);
+      }
+      default:
+        return false;
+    }
+  };
+
+  const handleControlCommand = (command: MaoyiControlCommand): void => {
+    if (command.type === 'security.visibility' && command.locked) {
+      clearRendererRuntime();
+      return;
+    }
+    if (command.type === 'window.hide' || command.type === 'shutdown') {
+      clearRendererRuntime();
+      return;
+    }
+    if (command.type === 'window.show') {
+      if (!canForward()) {
+        clearRendererRuntime();
+        return;
+      }
+      const requestId = randomUUID();
+      if (!requestLedger.beginSnapshot(requestId, true)) {
+        return;
+      }
+      if (
+        !sendRendererCommand({
+          type: 'message.snapshot.request',
+          requestId,
+        })
+      ) {
+        requestLedger.consume(requestId);
+      }
+      return;
+    }
+
+    if (
+      command.type !== 'message.snapshot.request' &&
+      command.type !== 'translation.cacheResultBatch'
+    ) {
+      return;
+    }
+    if (!canForward()) {
+      clearRendererRuntime();
+      return;
+    }
+
+    if (command.type === 'message.snapshot.request') {
+      if (!requestLedger.beginSnapshot(command.requestId)) {
+        return;
+      }
+      if (!sendRendererCommand(command)) {
+        requestLedger.consume(command.requestId);
+      }
+      return;
+    }
+
+    if (
+      currentConversationId !== command.conversationId ||
+      !requestLedger.acceptResult(command.requestId, command.conversationId)
+    ) {
+      return;
+    }
+    if (!sendRendererCommand(command)) {
+      requestLedger.consume(command.requestId);
+    }
+  };
+
+  ipcArgument.handle(maoyiMessageEventChannel, handleRendererEvent);
+  const removeCommandHandler = controlBridge.onCommand(handleControlCommand);
+  const removeTransportHandler = controlBridge.onTransportState(
+    authenticated => {
+      transportAuthenticated = authenticated;
+      if (!authenticated) {
+        clearRendererRuntime();
+      }
+    }
+  );
+
+  let attachedWindow: BrowserWindow | undefined;
+  const handleWindowUnavailable = (): void => {
+    clearRendererRuntime();
+  };
+  const handleWindowClosed = (): void => {
+    clearRendererRuntime();
+    mainWindow = undefined;
+  };
+  const handleRendererLoaded = (): void => {
+    clearRendererRuntime();
+  };
+
+  const removeWindowListeners = (): void => {
+    if (!attachedWindow) {
+      return;
+    }
+    attachedWindow.off('hide', handleWindowUnavailable);
+    attachedWindow.off('closed', handleWindowClosed);
+    if (!attachedWindow.webContents.isDestroyed()) {
+      attachedWindow.webContents.off('did-finish-load', handleRendererLoaded);
+    }
+    attachedWindow = undefined;
+  };
+
+  const messageBridge: MaoyiMessageBridge = Object.freeze({
+    attachMainWindow(window: BrowserWindow) {
+      if (stopped) {
+        return;
+      }
+      clearRendererRuntime();
+      removeWindowListeners();
+      mainWindow = window;
+      attachedWindow = window;
+      window.on('hide', handleWindowUnavailable);
+      window.on('closed', handleWindowClosed);
+      window.webContents.on('did-finish-load', handleRendererLoaded);
+      clearRendererRuntime();
+    },
+    stop() {
+      if (stopped) {
+        return;
+      }
+      stopped = true;
+      clearRendererRuntime();
+      removeWindowListeners();
+      ipcArgument.removeHandler(maoyiMessageEventChannel);
+      removeCommandHandler();
+      removeTransportHandler();
+      mainWindow = undefined;
+      requestLedger.clear();
+      Reflect.deleteProperty(globalThis, messageBridgeKey);
+    },
+  });
+  Reflect.set(globalThis, messageBridgeKey, messageBridge);
+  return messageBridge;
+}
