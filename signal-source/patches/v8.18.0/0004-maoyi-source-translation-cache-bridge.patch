+    );
+    assert.equal(
+      ipc.handler(event, {
+        type: 'translation.cacheResultApplied',
+        requestId,
+        appliedCount: 1,
+      }),
+      false
+    );
+
+    const foreignEvent = {
+      sender: new FakeWebContents() as unknown as WebContents,
+    } as IpcMainInvokeEvent;
+    const commandCountBeforeForeignEvent = window.webContents.commands.length;
+    assert.equal(
+      ipc.handler(foreignEvent, {
+        type: 'conversation.changed',
+        conversationId,
+      }),
+      false
+    );
+    assert.equal(
+      window.webContents.commands.length,
+      commandCountBeforeForeignEvent
+    );
+
+    control.emitCommand({
+      type: 'message.snapshot.request',
+      requestId: secondRequestId,
+    });
+    assert.deepEqual(window.webContents.commands.at(-1), {
+      type: 'message.snapshot.request',
+      requestId: secondRequestId,
+    });
+    const otherConversationId = '44444444-4444-4444-8444-444444444444';
+    assert.equal(
+      ipc.handler(event, {
+        type: 'conversation.changed',
+        conversationId: otherConversationId,
+      }),
+      true
+    );
+    assert.equal(
+      ipc.handler(event, {
+        type: 'message.visibleBatch',
