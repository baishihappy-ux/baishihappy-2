diff --git a/ts/maoyi/messageBatching.std.ts b/ts/maoyi/messageBatching.std.ts
new file mode 100644
index 0000000000000000000000000000000000000000..de3c0876b8ff05af97709f0d4d0c243203c5ad7d
--- /dev/null
+++ b/ts/maoyi/messageBatching.std.ts
@@ -0,0 +1,97 @@
+// Copyright 2026 Signal Messenger, LLC
+// SPDX-License-Identifier: AGPL-3.0-only
+
+import type { MaoyiMessageProjection } from './messageProjection.std.ts';
+
+export const maoyiVisibleBatchItemLimit = 100;
+export const maoyiVisibleBatchByteLimit = 768 * 1024;
+
+const requestIdBytePlaceholder = '00000000-0000-4000-8000-000000000000';
+
+function byteLength(value: unknown): number {
+  return new TextEncoder().encode(JSON.stringify(value)).byteLength;
+}
+
+export function createMaoyiVisibleProjectionSignature(
+  conversationId: string,
+  messages: ReadonlyArray<MaoyiMessageProjection>
+): string {
+  const messageIds = new Set<string>();
+  const identities: Array<ReadonlyArray<string>> = [];
+  for (const message of messages) {
+    const messageId = message.messageId.toLowerCase();
+    if (
+      message.conversationId !== conversationId ||
+      messageIds.has(messageId)
+    ) {
+      continue;
+    }
+    messageIds.add(messageId);
+    identities.push([messageId, message.sourceHash, message.sourceText]);
+  }
+  return JSON.stringify([conversationId, identities]);
+}
+
+export function maoyiVisibleBatchJsonBytes(
+  conversationId: string,
+  messages: ReadonlyArray<MaoyiMessageProjection>,
+  requestId = requestIdBytePlaceholder
+): number {
+  return byteLength({
+    type: 'message.visibleBatch',
+    requestId,
+    conversationId,
+    messages,
+  });
+}
+
+export function createMaoyiVisibleMessageBatches(
+  conversationId: string,
+  messages: ReadonlyArray<MaoyiMessageProjection>,
+  jsonByteLength: (value: unknown) => number = byteLength
+): Array<Array<MaoyiMessageProjection>> {
+  const batches: Array<Array<MaoyiMessageProjection>> = [];
+  let current: Array<MaoyiMessageProjection> = [];
+  const emptyBatchBytes = jsonByteLength({
+    type: 'message.visibleBatch',
+    requestId: requestIdBytePlaceholder,
+    conversationId,
+    messages: [],
+  });
+  let currentBytes = emptyBatchBytes;
+  const messageIds = new Set<string>();
+
+  for (const message of messages) {
+    const normalizedMessageId = message.messageId.toLowerCase();
+    if (
+      message.conversationId !== conversationId ||
+      messageIds.has(normalizedMessageId)
+    ) {
+      continue;
+    }
+    const messageBytes = jsonByteLength(message);
+    if (emptyBatchBytes + messageBytes > maoyiVisibleBatchByteLimit) {
+      continue;
+    }
+    const separatorBytes = current.length > 0 ? 1 : 0;
+    if (
+      current.length > 0 &&
+      (current.length >= maoyiVisibleBatchItemLimit ||
+        currentBytes + separatorBytes + messageBytes >
+          maoyiVisibleBatchByteLimit)
+    ) {
+      batches.push(current);
+      current = [];
+      currentBytes = emptyBatchBytes;
+    }
+
+    messageIds.add(normalizedMessageId);
+    currentBytes += (current.length > 0 ? 1 : 0) + messageBytes;
+    current.push(message);
+  }
+
+  if (current.length > 0 || batches.length === 0) {
+    batches.push(current);
+  }
+  return batches;
+}
diff --git a/ts/maoyi/messageBridge.preload.ts b/ts/maoyi/messageBridge.preload.ts
new file mode 100644
index 0000000000000000000000000000000000000000..89305b38f8ec66efa09a9409ec266770715095d6
--- /dev/null
+++ b/ts/maoyi/messageBridge.preload.ts
@@ -0,0 +1,530 @@
+// Copyright 2026 Signal Messenger, LLC
+// SPDX-License-Identifier: AGPL-3.0-only
+
+import { randomUUID } from 'node:crypto';
+import { ipcRenderer, type IpcRendererEvent } from 'electron';
+
+import {
+  maoyiTranslationMatchesProjection,
+  type MaoyiMessageProjection,
+  type MaoyiTranslationResult,
+} from './messageProjection.std.ts';
+import {
+  applyMaoyiTranslationBatch,
+  clearMaoyiTranslationRuntime,
+} from './translationRuntime.preload.ts';
+import {
+  createMaoyiVisibleProjectionSignature,
+  createMaoyiVisibleMessageBatches,
+  maoyiVisibleBatchByteLimit,
+  maoyiVisibleBatchItemLimit,
+} from './messageBatching.std.ts';
+import {
+  maoyiMessageCommandChannel,
+  maoyiMessageEventChannel,
+  type MaoyiRendererCommand,
+} from './messageBridgeChannels.std.ts';
+
+const rendererMessageBridgeKey = Symbol.for(
+  'maoyi.signal.renderer-message-bridge.v1'
+);
+const requestIdPattern =
+  /^[0-9a-f]{8}-[0-9a-f]{4}-[1-8][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$/i;
+const sourceHashPattern = /^(?:0|[1-9a-z][0-9a-z]{0,6})$/;
+const pendingRequestLimit = 128;
+const pendingRequestTtlMs = 30_000;
+const pendingProjectionByteLimit = 15 * 1024 * 1024;
+const maximumTextBytes = 64 * 1024;
+
+type Snapshot = Readonly<{
+  conversationId: string;
+  messages: ReadonlyArray<MaoyiMessageProjection>;
+}>;
+type SnapshotProvider = () => Snapshot | undefined;
+
+type PendingBatch = {
+  conversationId: string;
+  projections: ReadonlyMap<string, MaoyiMessageProjection>;
+  estimatedBytes: number;
+  expiresAt: number;
+};
+
+type MaoyiIpcRenderer = Readonly<{
+  invoke: (channel: string, value: unknown) => Promise<unknown>;
+  on: (
+    channel: string,
+    listener: (event: IpcRendererEvent, value: unknown) => void
+  ) => unknown;
+  off: (
+    channel: string,
+    listener: (event: IpcRendererEvent, value: unknown) => void
+  ) => unknown;
+}>;
+
+export type MaoyiRendererMessageBridge = Readonly<{
+  publishVisibleMessages: (
+    conversationId: string,
+    messages: ReadonlyArray<MaoyiMessageProjection>
+  ) => Promise<void>;
+  setSnapshotProvider: (provider: SnapshotProvider) => () => void;
+  clear: () => void;
+  stop: () => void;
+}>;
+
+function isRecord(value: unknown): value is Record<string, unknown> {
+  return typeof value === 'object' && value != null && !Array.isArray(value);
+}
+
+function hasOnlyKeys(
+  value: Record<string, unknown>,
+  allowed: ReadonlyArray<string>
+): boolean {
+  const keys = new Set(allowed);
+  return Object.keys(value).every(key => keys.has(key));
+}
+
+function isUuid(value: unknown): value is string {
+  return typeof value === 'string' && requestIdPattern.test(value);
+}
+
+function utf8Bytes(value: string): number {
+  return new TextEncoder().encode(value).byteLength;
+}
+
+function jsonBytes(value: unknown): number {
+  return utf8Bytes(JSON.stringify(value));
+}
+
+function parseTranslationResult(
+  value: unknown,
+  conversationId: string
+): MaoyiTranslationResult | undefined {
+  if (
+    !isRecord(value) ||
+    !hasOnlyKeys(value, [
+      'conversationId',
+      'messageId',
+      'sourceHash',
+      'sourceText',
+      'translatedText',
+    ]) ||
+    value.conversationId !== conversationId ||
+    !isUuid(value.messageId) ||
+    typeof value.sourceHash !== 'string' ||
+    !sourceHashPattern.test(value.sourceHash) ||
+    typeof value.sourceText !== 'string' ||
+    value.sourceText.length === 0 ||
+    utf8Bytes(value.sourceText) > maximumTextBytes ||
+    typeof value.translatedText !== 'string' ||
+    value.translatedText.length === 0 ||
+    utf8Bytes(value.translatedText) > maximumTextBytes
+  ) {
+    return undefined;
+  }
+  return {
+    conversationId,
+    messageId: value.messageId,
+    sourceHash: value.sourceHash,
+    sourceText: value.sourceText,
+    translatedText: value.translatedText,
+  };
+}
+
+function parseRendererCommand(
+  value: unknown
+): MaoyiRendererCommand | undefined {
+  if (
+    !isRecord(value) ||
+    typeof value.type !== 'string' ||
+    jsonBytes(value) > maoyiVisibleBatchByteLimit
+  ) {
+    return undefined;
+  }
+  if (
+    value.type === 'translation.runtime.clear' &&
+    hasOnlyKeys(value, ['type'])
+  ) {
+    return { type: 'translation.runtime.clear' };
+  }
+  if (
+    value.type === 'message.snapshot.request' &&
+    hasOnlyKeys(value, ['type', 'requestId']) &&
+    isUuid(value.requestId)
+  ) {
+    return {
+      type: 'message.snapshot.request',
+      requestId: value.requestId,
+    };
+  }
+  if (
+    value.type !== 'translation.cacheResultBatch' ||
+    !hasOnlyKeys(value, ['type', 'requestId', 'conversationId', 'results']) ||
+    !isUuid(value.requestId) ||
+    !isUuid(value.conversationId) ||
+    !Array.isArray(value.results) ||
+    value.results.length > maoyiVisibleBatchItemLimit
+  ) {
+    return undefined;
+  }
+
+  const results: Array<MaoyiTranslationResult> = [];
+  const messageIds = new Set<string>();
+  for (const item of value.results) {
+    const parsed = parseTranslationResult(item, value.conversationId);
+    const normalizedMessageId = parsed?.messageId.toLowerCase();
+    if (
+      !parsed ||
+      !normalizedMessageId ||
+      messageIds.has(normalizedMessageId)
+    ) {
+      return undefined;
+    }
+    messageIds.add(normalizedMessageId);
+    results.push(parsed);
+  }
+  return {
+    type: 'translation.cacheResultBatch',
+    requestId: value.requestId,
+    conversationId: value.conversationId,
+    results,
+  };
+}
+
+export function createMaoyiRendererMessageBridge(
+  transport: MaoyiIpcRenderer = ipcRenderer
+): MaoyiRendererMessageBridge {
+  const pending = new Map<string, PendingBatch>();
+  let pendingBytes = 0;
+  let announcedConversationId: string | undefined;
+  let activeProjectionSignature: string | undefined;
+  let snapshotProvider: SnapshotProvider | undefined;
+  let securityGeneration = 0;
+  let normalPublishRevision = 0;
+  let queue: Promise<void> = Promise.resolve();
+  let stopped = false;
+
+  const removePending = (requestId: string): PendingBatch | undefined => {
+    const value = pending.get(requestId);
+    if (!value) {
+      return undefined;
+    }
+    pending.delete(requestId);
+    pendingBytes = Math.max(0, pendingBytes - value.estimatedBytes);
+    return value;
+  };
+
+  const prunePending = (): void => {
+    const now = Date.now();
+    for (const [requestId, value] of pending) {
+      if (value.expiresAt <= now) {
+        removePending(requestId);
+      }
+    }
+  };
+
+  const clearPending = (): void => {
+    pending.clear();
+    pendingBytes = 0;
+  };
+
+  const reservePending = (
+    requestId: string,
+    conversationId: string,
+    messages: ReadonlyArray<MaoyiMessageProjection>
+  ): boolean => {
+    prunePending();
+    if (pending.has(requestId)) {
+      return false;
+    }
+
+    const estimatedBytes = jsonBytes(messages);
+    if (estimatedBytes > pendingProjectionByteLimit) {
+      return false;
+    }
+    while (
+      pending.size >= pendingRequestLimit ||
+      pendingBytes + estimatedBytes > pendingProjectionByteLimit
+    ) {
+      const oldest = pending.keys().next();
+      if (oldest.done) {
+        return false;
+      }
+      removePending(oldest.value);
+    }
+
+    pending.set(requestId, {
+      conversationId,
+      projections: new Map(messages.map(item => [item.messageId, item])),
+      estimatedBytes,
+      expiresAt: Date.now() + pendingRequestTtlMs,
+    });
+    pendingBytes += estimatedBytes;
+    return true;
+  };
+
+  const sendEvent = async (value: unknown): Promise<boolean> => {
+    try {
+      return (
+        (await transport.invoke(maoyiMessageEventChannel, value)) === true
+      );
+    } catch {
+      return false;
+    }
+  };
+
+  const runPublish = async (
+    snapshot: Snapshot,
+    generation: number,
+    forcedRequestId?: string,
+    revision?: number
+  ): Promise<void> => {
+    if (
+      stopped ||
+      generation !== securityGeneration ||
+      (revision != null && revision !== normalPublishRevision) ||
+      !isUuid(snapshot.conversationId)
+    ) {
+      return;
+    }
+
+    if (announcedConversationId !== snapshot.conversationId) {
+      clearPending();
+      activeProjectionSignature = undefined;
+      if (
+        !(await sendEvent({
+          type: 'conversation.changed',
+          conversationId: snapshot.conversationId,
+        })) ||
+        stopped ||
+        generation !== securityGeneration ||
+        (revision != null && revision !== normalPublishRevision)
+      ) {
+        announcedConversationId = undefined;
+        return;
+      }
+      announcedConversationId = snapshot.conversationId;
+    }
+
+    const projectionSignature = createMaoyiVisibleProjectionSignature(
+      snapshot.conversationId,
+      snapshot.messages
+    );
+    if (activeProjectionSignature === projectionSignature && !forcedRequestId) {
+      return;
+    }
+    if (
+      activeProjectionSignature != null &&
+      activeProjectionSignature !== projectionSignature
+    ) {
+      clearPending();
+    }
+    activeProjectionSignature = projectionSignature;
+
+    const batches = createMaoyiVisibleMessageBatches(
+      snapshot.conversationId,
+      snapshot.messages
+    );
+    let allBatchesAccepted = true;
+    for (let index = 0; index < batches.length; index += 1) {
+      if (
+        stopped ||
+        generation !== securityGeneration ||
+        (revision != null && revision !== normalPublishRevision)
+      ) {
+        if (
+          generation === securityGeneration &&
+          activeProjectionSignature === projectionSignature
+        ) {
+          activeProjectionSignature = undefined;
+        }
+        return;
+      }
+      const messages = batches[index] ?? [];
+      const requestId =
+        index === 0 && forcedRequestId ? forcedRequestId : randomUUID();
+      if (!reservePending(requestId, snapshot.conversationId, messages)) {
+        allBatchesAccepted = false;
+        continue;
+      }
+      // Batches must preserve their visible-order request sequence.
+      // oxlint-disable-next-line no-await-in-loop
+      const accepted = await sendEvent({
+        type: 'message.visibleBatch',
+        requestId,
+        conversationId: snapshot.conversationId,
+        messages,
+      });
+      if (!accepted) {
+        allBatchesAccepted = false;
+        removePending(requestId);
+      }
+    }
+    if (
+      (!allBatchesAccepted ||
+        generation !== securityGeneration ||
+        (revision != null && revision !== normalPublishRevision)) &&
+      activeProjectionSignature === projectionSignature
+    ) {
+      activeProjectionSignature = undefined;
+    }
+  };
+
+  const enqueue = (work: () => Promise<void>): Promise<void> => {
+    // This is a deliberately serialized, bounded renderer publication queue.
+    // oxlint-disable-next-line promise/prefer-await-to-then, signal-desktop/no-then
+    const next = queue.then(work, work);
+    // oxlint-disable-next-line promise/prefer-await-to-then
+    queue = next.catch(() => undefined);
+    return next;
+  };
+
+  const handleResultBatch = async (
+    command: Extract<
+      MaoyiRendererCommand,
+      { type: 'translation.cacheResultBatch' }
+    >
+  ): Promise<void> => {
+    const expected = removePending(command.requestId);
+    let appliedCount = 0;
+    if (
+      expected &&
+      expected.conversationId === command.conversationId &&
+      command.results.every(result => {
+        const projection = expected.projections.get(result.messageId);
+        return Boolean(
+          projection && maoyiTranslationMatchesProjection(projection, result)
+        );
+      })
+    ) {
+      appliedCount = applyMaoyiTranslationBatch(command.results);
+    }
+    await sendEvent({
+      type: 'translation.cacheResultApplied',
+      requestId: command.requestId,
+      appliedCount,
+    });
+  };
+
+  const handleCommand = (_event: IpcRendererEvent, value: unknown): void => {
+    const command = parseRendererCommand(value);
+    if (!command) {
+      return;
+    }
+    if (command.type === 'translation.runtime.clear') {
+      securityGeneration += 1;
+      normalPublishRevision += 1;
+      announcedConversationId = undefined;
+      activeProjectionSignature = undefined;
+      clearPending();
+      clearMaoyiTranslationRuntime();
+      return;
+    }
+    if (command.type === 'translation.cacheResultBatch') {
+      void handleResultBatch(command);
+      return;
+    }
+
+    const generation = securityGeneration;
+    void enqueue(async () => {
+      if (stopped || generation !== securityGeneration) {
+        return;
+      }
+      const snapshot = snapshotProvider?.();
+      if (!snapshot) {
+        return;
+      }
+      const revision = normalPublishRevision;
+      await runPublish(snapshot, generation, command.requestId, revision);
+    });
+  };
+
+  transport.on(maoyiMessageCommandChannel, handleCommand);
+
+  return Object.freeze({
+    publishVisibleMessages(
+      conversationId: string,
+      messages: ReadonlyArray<MaoyiMessageProjection>
+    ) {
+      normalPublishRevision += 1;
+      const revision = normalPublishRevision;
+      const generation = securityGeneration;
+      return enqueue(() =>
+        runPublish(
+          { conversationId, messages },
+          generation,
+          undefined,
+          revision
+        )
+      );
+    },
+    setSnapshotProvider(provider: SnapshotProvider) {
+      snapshotProvider = provider;
+      return () => {
+        if (snapshotProvider === provider) {
+          snapshotProvider = undefined;
+        }
+      };
+    },
+    clear() {
+      securityGeneration += 1;
+      normalPublishRevision += 1;
+      announcedConversationId = undefined;
+      activeProjectionSignature = undefined;
+      clearPending();
+      clearMaoyiTranslationRuntime();
+    },
+    stop() {
+      if (stopped) {
+        return;
+      }
+      stopped = true;
+      securityGeneration += 1;
+      normalPublishRevision += 1;
+      transport.off(maoyiMessageCommandChannel, handleCommand);
+      snapshotProvider = undefined;
+      announcedConversationId = undefined;
+      activeProjectionSignature = undefined;
+      clearPending();
+      clearMaoyiTranslationRuntime();
+    },
+  });
+}
+
+export function startMaoyiRendererMessageBridge(): MaoyiRendererMessageBridge {
+  const existing = Reflect.get(globalThis, rendererMessageBridgeKey) as
+    | MaoyiRendererMessageBridge
+    | undefined;
+  if (existing) {
+    return existing;
+  }
+  const bridge = createMaoyiRendererMessageBridge();
+  Reflect.set(globalThis, rendererMessageBridgeKey, bridge);
+  return bridge;
+}
+
+function getRendererMessageBridge(): MaoyiRendererMessageBridge | undefined {
+  return Reflect.get(globalThis, rendererMessageBridgeKey) as
+    | MaoyiRendererMessageBridge
+    | undefined;
+}
+
+export function publishMaoyiVisibleMessages(
+  conversationId: string,
+  messages: ReadonlyArray<MaoyiMessageProjection>
+): Promise<void> {
+  return (
+    getRendererMessageBridge()?.publishVisibleMessages(
+      conversationId,
+      messages
+    ) ?? Promise.resolve()
+  );
+}
+
+export function setMaoyiSnapshotProvider(
+  provider: SnapshotProvider
+): () => void {
+  return (
+    getRendererMessageBridge()?.setSnapshotProvider(provider) ??
+    (() => undefined)
+  );
+}
