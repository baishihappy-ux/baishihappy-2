+const secondRequestId = '55555555-5555-4555-8555-555555555555';
+
+class FakeWebContents extends EventEmitter {
+  public destroyed = false;
+  public readonly commands: Array<unknown> = [];
+
+  public isDestroyed(): boolean {
+    return this.destroyed;
+  }
+
+  public send(channel: string, command: unknown): void {
+    assert.equal(channel, maoyiMessageCommandChannel);
+    this.commands.push(command);
+  }
+}
+
+// oxlint-disable-next-line max-classes-per-file
+class FakeWindow extends EventEmitter {
+  public destroyed = false;
+  public visible = true;
+  public readonly webContents = new FakeWebContents();
+
+  public isDestroyed(): boolean {
+    return this.destroyed;
+  }
+
+  public isVisible(): boolean {
+    return this.visible;
+  }
+}
+
+class FakeIpcMain {
+  public handler:
+    | ((event: IpcMainInvokeEvent, value: unknown) => boolean)
+    | undefined;
+
+  public handle(
+    channel: string,
+    handler: (event: IpcMainInvokeEvent, value: unknown) => boolean
+  ): void {
+    assert.equal(channel, maoyiMessageEventChannel);
+    this.handler = handler;
+  }
+
+  public removeHandler(channel: string): void {
