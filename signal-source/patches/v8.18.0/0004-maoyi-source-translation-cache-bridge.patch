@@ -0,0 +1,43 @@
+// Copyright 2026 Signal Messenger, LLC
+// SPDX-License-Identifier: AGPL-3.0-only
+
+import assert from 'node:assert/strict';
+import { readFileSync } from 'node:fs';
+
+describe('Maoyi translation slot', () => {
+  it('places metadata below translated text and preserves hidden metadata', () => {
+    const source = readFileSync(
+      'ts/components/conversation/Message.dom.tsx',
+      'utf8'
+    );
+    const methodStart = source.indexOf('#getMetadataPlacement(');
+    const methodEnd = source.indexOf(
+      '\n  public startTargetedTimer',
+      methodStart
+    );
+    assert.notEqual(methodStart, -1);
+    assert.notEqual(methodEnd, -1);
+    const method = source.slice(methodStart, methodEnd);
+
+    const hiddenIndex = method.indexOf('return MetadataPlacement.NotRendered;');
+    const translationIndex = method.indexOf('if (maoyiTranslationText)');
+    const bottomIndex = method.indexOf(
+      'return MetadataPlacement.Bottom;',
+      translationIndex
+    );
+    assert.ok(hiddenIndex >= 0);
+    assert.ok(translationIndex > hiddenIndex);
+    assert.ok(bottomIndex > translationIndex);
+  });
+
+  it('renders translation as escaped React text with language direction hints', () => {
+    const source = readFileSync(
+      'ts/components/conversation/Message.dom.tsx',
+      'utf8'
+    );
+    assert.match(source, /className="module-message__maoyi-translation"/);
+    assert.match(source, /dir="auto"/);
+    assert.match(source, /lang="zh-CN"/);
+    assert.match(source, /\{maoyiTranslationText\}/);
+  });
+});
