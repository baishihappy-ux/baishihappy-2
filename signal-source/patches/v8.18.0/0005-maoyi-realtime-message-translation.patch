+// oxlint-disable-next-line max-classes-per-file
+export class MaoyiAddedMessageLedger {
+  readonly #entries = new Map<string, number>();
+  readonly #now: () => number;
+  readonly #limit: number;
+  readonly #ttlMs: number;
+
+  constructor(
+    now: () => number = Date.now,
+    limit = maoyiRequestCorrelationLimit,
+    ttlMs = maoyiRequestCorrelationTtlMs
+  ) {
+    this.#now = now;
+    this.#limit = limit;
+    this.#ttlMs = ttlMs;
+  }
+
+  #prune(): void {
+    const now = this.#now();
+    for (const [messageId, expiresAt] of this.#entries) {
+      if (expiresAt <= now) {
+        this.#entries.delete(messageId);
+      }
+    }
+  }
+
+  accept(messageId: string): boolean {
+    this.#prune();
+    const normalizedMessageId = messageId.toLowerCase();
+    if (this.#entries.has(normalizedMessageId)) {
+      return false;
+    }
+    while (this.#entries.size >= this.#limit) {
+      const oldest = this.#entries.keys().next();
+      if (oldest.done) {
+        return false;
+      }
+      this.#entries.delete(oldest.value);
+    }
+    this.#entries.set(normalizedMessageId, this.#now() + this.#ttlMs);
+    return true;
+  }
+
+  remove(messageId: string): void {
+    this.#entries.delete(messageId.toLowerCase());
+  }
+
+  clear(): void {
+    this.#entries.clear();
+  }
+}
