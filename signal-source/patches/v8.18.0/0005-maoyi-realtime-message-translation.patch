diff --git a/ts/maoyi/messageAddedObserver.std.ts b/ts/maoyi/messageAddedObserver.std.ts
new file mode 100644
index 0000000..f6750e3
--- /dev/null
+++ b/ts/maoyi/messageAddedObserver.std.ts
@@ -0,0 +1,101 @@
+// Copyright 2026 Signal Messenger, LLC
+// SPDX-License-Identifier: AGPL-3.0-only
+
+import type { UnknownAction } from 'redux';
+
+import type { StateType } from '../state/reducer.preload.ts';
+import { getSelectedConversationId } from '../state/selectors/nav.std.ts';
+import type { MaoyiMessageProjection } from './messageProjection.std.ts';
+import { projectMaoyiVisibleMessages } from './visibleMessageProjection.std.ts';
+
+type ParsedMessagesAddedAction = Readonly<{
+  conversationId: string;
+  isActive: boolean;
+  messageId: string;
+}>;
+
+function isRecord(value: unknown): value is Record<string, unknown> {
+  return typeof value === 'object' && value != null && !Array.isArray(value);
+}
+
+function hasOnlyKeys(
+  value: Record<string, unknown>,
+  allowed: ReadonlyArray<string>
+): boolean {
+  const allowedKeys = new Set(allowed);
+  return Object.keys(value).every(key => allowedKeys.has(key));
+}
+
+function parseMessagesAddedAction(
+  action: UnknownAction
+): ParsedMessagesAddedAction | undefined {
+  if (action.type !== 'MESSAGES_ADDED' || !isRecord(action.payload)) {
+    return undefined;
+  }
+  const payload = action.payload;
+  if (
+    !hasOnlyKeys(payload, [
+      'conversationId',
+      'isActive',
+      'isJustSent',
+      'isNewMessage',
+      'messages',
+    ]) ||
+    typeof payload.conversationId !== 'string' ||
+    typeof payload.isActive !== 'boolean' ||
+    typeof payload.isJustSent !== 'boolean' ||
+    payload.isNewMessage !== true ||
+    !Array.isArray(payload.messages) ||
+    payload.messages.length !== 1
+  ) {
+    return undefined;
+  }
+
+  const [message] = payload.messages;
+  if (
+    !isRecord(message) ||
+    typeof message.id !== 'string' ||
+    message.conversationId !== payload.conversationId
+  ) {
+    return undefined;
+  }
+
+  return {
+    conversationId: payload.conversationId,
+    isActive: payload.isActive,
+    messageId: message.id,
+  };
+}
+
+export function projectMaoyiAddedMessageFromAction(
+  beforeState: StateType,
+  action: UnknownAction,
+  afterState: StateType
+): MaoyiMessageProjection | undefined {
+  const parsed = parseMessagesAddedAction(action);
+  if (!parsed) {
+    return undefined;
+  }
+
+  const { conversationId, messageId } = parsed;
+  if (
+    getSelectedConversationId(beforeState) !== conversationId ||
+    getSelectedConversationId(afterState) !== conversationId ||
+    beforeState.conversations.messagesLookup[messageId] != null
+  ) {
+    return undefined;
+  }
+
+  const conversation =
+    afterState.conversations.messagesByConversation[conversationId];
+  if (!conversation?.messageIds.includes(messageId)) {
+    return undefined;
+  }
+
+  const projections = projectMaoyiVisibleMessages(
+    conversationId,
+    [messageId],
+    afterState.conversations.messagesLookup
+  );
+  return projections.length === 1 ? projections[0] : undefined;
+}

