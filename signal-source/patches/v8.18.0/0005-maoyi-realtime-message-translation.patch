@@ -0,0 +1,172 @@
+// Copyright 2026 Signal Messenger, LLC
+// SPDX-License-Identifier: AGPL-3.0-only
+
+import assert from 'node:assert/strict';
+import type { UnknownAction } from 'redux';
+
+// This observer is pure and does not require Electron renderer globals.
+import { projectMaoyiAddedMessageFromAction } from '../../maoyi/messageAddedObserver.std.ts';
+import { legacyMaoyiSourceHash } from '../../maoyi/messageProjection.std.ts';
+import type { StateType } from '../../state/reducer.preload.ts';
+import { NavTab } from '../../types/Nav.std.ts';
+
+const conversationId = '22222222-2222-4222-8222-222222222222';
+const otherConversationId = '44444444-4444-4444-8444-444444444444';
+const messageId = '33333333-3333-4333-8333-333333333333';
+
+const message = {
+  id: messageId,
+  conversationId,
+  type: 'incoming',
+  body: 'Hello world',
+  timestamp: 1_800_000_000_000,
+};
+
+function state(
+  selectedConversationId: string,
+  messages: ReadonlyArray<Record<string, unknown>> = []
+): StateType {
+  const messagesLookup = Object.fromEntries(
+    messages.map(item => [String(item.id), item])
+  );
+  return {
+    nav: {
+      selectedLocation: {
+        tab: NavTab.Chats,
+        details: { conversationId: selectedConversationId },
+      },
+    },
+    conversations: {
+      messagesLookup,
+      messagesByConversation: {
+        [conversationId]: {
+          messageIds: messages
+            .filter(item => item.conversationId === conversationId)
+            .map(item => String(item.id)),
+        },
+      },
+    },
+  } as unknown as StateType;
+}
+
+function addedAction(
+  overrides: Readonly<Record<string, unknown>> = {}
+): UnknownAction {
+  return {
+    type: 'MESSAGES_ADDED',
+    payload: {
+      conversationId,
+      isActive: true,
+      isJustSent: false,
+      isNewMessage: true,
+      messages: [message],
+      ...overrides,
+    },
+  };
+}
+
+describe('Maoyi message-added observer', () => {
+  it('projects one reducer-accepted safe message in the selected conversation when isActive is false', () => {
+    const projected = projectMaoyiAddedMessageFromAction(
+      state(conversationId),
+      addedAction({ isActive: false }),
+      state(conversationId, [message])
+    );
+
+    assert.deepEqual(projected, {
+      conversationId,
+      messageId,
+      sourceHash: legacyMaoyiSourceHash('Hello world'),
+      sourceText: 'Hello world',
+      direction: 'incoming',
+      timestamp: message.timestamp,
+    });
+  });
+
+  it('rejects history, non-boolean activity, background-conversation, replay, and reducer-dropped actions', () => {
+    const before = state(conversationId);
+    const after = state(conversationId, [message]);
+
+    assert.equal(
+      projectMaoyiAddedMessageFromAction(
+        before,
+        addedAction({ isNewMessage: false }),
+        after
+      ),
+      undefined
+    );
+    assert.equal(
+      projectMaoyiAddedMessageFromAction(
+        before,
+        addedAction({ isActive: 'false' }),
+        after
+      ),
+      undefined
+    );
+    assert.equal(
+      projectMaoyiAddedMessageFromAction(
+        state(otherConversationId),
+        addedAction(),
+        state(otherConversationId, [message])
+      ),
+      undefined
+    );
+    assert.equal(
+      projectMaoyiAddedMessageFromAction(
+        state(conversationId, [message]),
+        addedAction(),
+        after
+      ),
+      undefined
+    );
+    assert.equal(
+      projectMaoyiAddedMessageFromAction(
+        before,
+        addedAction(),
+        state(conversationId)
+      ),
+      undefined
+    );
+  });
+
+  it('rejects batches, cross-conversation payloads, and unsafe message bodies', () => {
+    const before = state(conversationId);
+
+    assert.equal(
+      projectMaoyiAddedMessageFromAction(
+        before,
+        addedAction({
+          messages: [message, { ...message, id: otherConversationId }],
+        }),
+        state(conversationId, [message])
+      ),
+      undefined
+    );
+    assert.equal(
+      projectMaoyiAddedMessageFromAction(
+        before,
+        addedAction({
+          messages: [{ ...message, conversationId: otherConversationId }],
+        }),
+        state(conversationId, [message])
+      ),
+      undefined
+    );
+
+    for (const unsafe of [
+      { ...message, body: '你好' },
+      { ...message, attachments: [{ contentType: 'image/png' }] },
+      { ...message, poll: { question: 'Hello?' } },
+      { ...message, timestamp: 1.5 },
+    ]) {
+      assert.equal(
+        projectMaoyiAddedMessageFromAction(
+          before,
+          addedAction({ messages: [unsafe] }),
+          state(conversationId, [unsafe])
+        ),
+        undefined
+      );
+    }
+  });
+});

