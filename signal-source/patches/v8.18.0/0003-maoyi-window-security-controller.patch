--- /dev/null
+++ b/app/maoyi/windowsOwner.node.ts
@@ -0,0 +1,25 @@
+// Copyright 2026 Signal Messenger, LLC
+// SPDX-License-Identifier: AGPL-3.0-only
+
+import { setWindowOwner } from '@signalapp/windows-ucv';
+import type { BrowserWindow } from 'electron';
+
+export type MaoyiOwnerDescriptor = Readonly<{
+  handle: string;
+  ownerProcessId: number;
+}>;
+
+export function applyMaoyiWindowOwner(
+  window: BrowserWindow,
+  descriptor: MaoyiOwnerDescriptor
+): boolean {
+  if (process.platform !== 'win32') {
+    return false;
+  }
+  const childHandle = Buffer.from(window.getNativeWindowHandle());
+  const ownerHandle = Buffer.from(descriptor.handle, 'base64url');
+  if (childHandle.length !== 8 || ownerHandle.length !== 8) {
+    return false;
+  }
+  return setWindowOwner(childHandle, ownerHandle, descriptor.ownerProcessId);
+}
