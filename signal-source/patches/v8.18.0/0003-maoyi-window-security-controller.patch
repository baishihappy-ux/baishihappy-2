+/**
+ * Assign a verified top-level owner to a window in this process.
+ *
+ * The native implementation validates both HWND process identifiers and uses
+ * GWLP_HWNDPARENT. It intentionally does not use SetParent, which would turn a
+ * top-level Electron window into a cross-process child window.
+ */
+export function setWindowOwner(
+  childHandle: Buffer<ArrayBuffer>,
+  ownerHandle: Buffer<ArrayBuffer>,
+  ownerProcessId: number,
+): boolean {
+  if (!binding) {
+    throw new Error('This library works only on Windows');
+  }
+  return binding.setWindowOwner(childHandle, ownerHandle, ownerProcessId);
+}
