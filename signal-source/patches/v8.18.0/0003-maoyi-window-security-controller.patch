@@ -0,0 +1,400 @@
+// Copyright 2026 Signal Messenger, LLC
+// SPDX-License-Identifier: AGPL-3.0-only
+
+import { createHmac, timingSafeEqual } from 'node:crypto';
+
+export const maoyiControlProtocolVersion = 1;
+export const maoyiControlMaxMessageBytes = 1024 * 1024;
+export const maoyiControlHeartbeatMs = 5_000;
+export const maoyiControlReconnectMs = 1_000;
+
+export type MaoyiWindowBounds = Readonly<{
+  x: number;
+  y: number;
+  width: number;
+  height: number;
+}>;
+
+export type MaoyiControlCommand =
+  | Readonly<{ type: 'hello'; appId: string; at: number }>
+  | Readonly<{ type: 'heartbeat.ack'; at: number }>
+  | Readonly<{
+      type: 'security.visibility';
+      locked: boolean;
+      revision: number;
+    }>
+  | Readonly<{
+      type: 'window.owner';
+      handle: string;
+      ownerProcessId: number;
+    }>
+  | Readonly<{ type: 'window.show'; bounds?: MaoyiWindowBounds }>
+  | Readonly<{ type: 'window.focus' }>
+  | Readonly<{ type: 'window.hide' }>
+  | Readonly<{
+      type: 'window.bounds-changed';
+      bounds: MaoyiWindowBounds;
+    }>
+  | Readonly<{ type: 'protocol.open'; url: string; requestId?: string }>
+  | Readonly<{ type: 'shutdown' }>
+  | Readonly<{ type: 'script.execute'; requestId: string; script: string }>;
+
+export type MaoyiControlEvent =
+  | Readonly<{ type: 'ready'; title?: string }>
+  | Readonly<{ type: 'heartbeat'; visible: boolean }>
+  | Readonly<{ type: 'window.group-focused' }>
+  | Readonly<{ type: 'window.group-blurred' }>
+  | Readonly<{
+      type: 'window.state';
+      visible: boolean;
+      bounds?: MaoyiWindowBounds;
+    }>
+  | Readonly<{ type: 'window.bounds'; bounds: MaoyiWindowBounds }>
+  | Readonly<{ type: 'window.visibility-changed'; visible: boolean }>
+  | Readonly<{
+      type: 'window.bounds-changed';
+      bounds: MaoyiWindowBounds;
+    }>
+  | Readonly<{ type: 'window.closed' }>
+  | Readonly<{ type: 'closed' }>
+  | Readonly<{ type: 'window.owner-attached'; ownerProcessId: number }>
+  | Readonly<{
+      type: 'security.visibility-applied';
+      locked: boolean;
+      revision: number;
+      visibleWindowCount: number;
+    }>
+  | Readonly<{ type: 'shutdown.ack' }>
+  | Readonly<{ type: 'protocol.opened'; requestId?: string }>
+  | Readonly<{ type: 'script.result'; requestId: string; result: unknown }>
+  | Readonly<{ type: 'error'; requestId?: string; message: string }>
+  | Readonly<{ type: 'transport.error'; code: string }>;
+
+type MaoyiControlPayload<T> = Readonly<{
+  appId: string;
+  at: number;
+}> &
+  T;
+
+type MaoyiControlEnvelope<T> = Readonly<{
+  version: 1;
+  sequence: number;
+  payload: T;
+  mac: string;
+}>;
+
+type MaoyiAuthChallenge = Readonly<{
+  type: 'auth.challenge';
+  appId: string;
+  challenge: string;
+}>;
+
+function isRecord(value: unknown): value is Record<string, unknown> {
+  return typeof value === 'object' && value != null && !Array.isArray(value);
+}
+
+function hasOnlyKeys(
+  value: Record<string, unknown>,
+  allowed: ReadonlyArray<string>
+): boolean {
+  const allowedKeys = new Set(allowed);
+  return Object.keys(value).every(key => allowedKeys.has(key));
+}
+
+function isFiniteIntegerInRange(
+  value: unknown,
+  minimum: number,
+  maximum: number
+): value is number {
+  return (
+    typeof value === 'number' &&
+    Number.isFinite(value) &&
+    Number.isInteger(value) &&
+    value >= minimum &&
+    value <= maximum
+  );
+}
+
+function parseBounds(value: unknown): MaoyiWindowBounds | undefined {
+  if (
+    !isRecord(value) ||
+    !hasOnlyKeys(value, ['x', 'y', 'width', 'height']) ||
+    !isFiniteIntegerInRange(value.x, -100_000, 100_000) ||
+    !isFiniteIntegerInRange(value.y, -100_000, 100_000) ||
+    !isFiniteIntegerInRange(value.width, 1, 20_000) ||
+    !isFiniteIntegerInRange(value.height, 1, 20_000)
+  ) {
+    return undefined;
+  }
+  return {
+    x: value.x,
+    y: value.y,
+    width: value.width,
+    height: value.height,
+  };
+}
+
+function isBoundedString(
+  value: unknown,
+  maximumBytes: number
+): value is string {
+  return (
+    typeof value === 'string' &&
+    Buffer.byteLength(value, 'utf8') <= maximumBytes
+  );
+}
+
+export function parseMaoyiControlCommand(
+  value: unknown
+): MaoyiControlCommand | undefined {
+  if (!isRecord(value) || typeof value.type !== 'string') {
+    return undefined;
+  }
+
+  switch (value.type) {
+    case 'hello':
+      if (
+        hasOnlyKeys(value, ['type', 'appId', 'at']) &&
+        isBoundedString(value.appId, 160) &&
+        isFiniteIntegerInRange(value.at, 0, Number.MAX_SAFE_INTEGER)
+      ) {
+        return { type: 'hello', appId: value.appId, at: value.at };
+      }
+      return undefined;
+    case 'heartbeat.ack':
+      if (
+        hasOnlyKeys(value, ['type', 'at']) &&
+        isFiniteIntegerInRange(value.at, 0, Number.MAX_SAFE_INTEGER)
+      ) {
+        return { type: 'heartbeat.ack', at: value.at };
+      }
+      return undefined;
+    case 'security.visibility':
+      if (
+        hasOnlyKeys(value, ['type', 'locked', 'revision']) &&
+        typeof value.locked === 'boolean' &&
+        isFiniteIntegerInRange(value.revision, 0, Number.MAX_SAFE_INTEGER)
+      ) {
+        return {
+          type: 'security.visibility',
+          locked: value.locked,
+          revision: value.revision,
+        };
+      }
+      return undefined;
+    case 'window.owner':
+      if (
+        hasOnlyKeys(value, ['type', 'handle', 'ownerProcessId']) &&
+        typeof value.handle === 'string' &&
+        /^[A-Za-z0-9_-]{11}$/.test(value.handle) &&
+        Buffer.from(value.handle, 'base64url').length === 8 &&
+        isFiniteIntegerInRange(value.ownerProcessId, 1, 0xffffffff)
+      ) {
+        return {
+          type: 'window.owner',
+          handle: value.handle,
+          ownerProcessId: value.ownerProcessId,
+        };
+      }
+      return undefined;
+    case 'window.show': {
+      if (!hasOnlyKeys(value, ['type', 'bounds'])) {
+        return undefined;
+      }
+      if (value.bounds == null) {
+        return { type: 'window.show' };
+      }
+      const bounds = parseBounds(value.bounds);
+      return bounds ? { type: 'window.show', bounds } : undefined;
+    }
+    case 'window.focus':
+    case 'window.hide':
+    case 'shutdown':
+      return hasOnlyKeys(value, ['type'])
+        ? ({ type: value.type } as MaoyiControlCommand)
+        : undefined;
+    case 'window.bounds-changed': {
+      if (!hasOnlyKeys(value, ['type', 'bounds'])) {
+        return undefined;
+      }
+      const bounds = parseBounds(value.bounds);
+      return bounds ? { type: 'window.bounds-changed', bounds } : undefined;
+    }
+    case 'protocol.open': {
+      if (
+        !hasOnlyKeys(value, ['type', 'url', 'requestId']) ||
+        !isBoundedString(value.url, 4_096) ||
+        !/^(?:sgnl|signalcaptcha):/i.test(value.url) ||
+        (value.requestId != null && !isBoundedString(value.requestId, 160))
+      ) {
+        return undefined;
+      }
+      return {
+        type: 'protocol.open',
+        url: value.url,
+        requestId:
+          typeof value.requestId === 'string' ? value.requestId : undefined,
+      };
+    }
+    case 'script.execute':
+      if (
+        hasOnlyKeys(value, ['type', 'requestId', 'script']) &&
+        isBoundedString(value.requestId, 160) &&
+        isBoundedString(value.script, 900 * 1024)
+      ) {
+        return {
+          type: 'script.execute',
+          requestId: value.requestId,
+          script: value.script,
+        };
+      }
+      return undefined;
+    default:
+      return undefined;
+  }
+}
+
+function controlMac(
+  key: Buffer<ArrayBuffer>,
+  values: ReadonlyArray<unknown>
+): string {
+  return createHmac('sha256', key)
+    .update(JSON.stringify(values))
+    .digest('base64url');
+}
+
+function constantTimeBase64UrlEqual(
+  actual: unknown,
+  expected: string
+): boolean {
+  if (typeof actual !== 'string') {
+    return false;
+  }
+  try {
+    const actualBuffer = Buffer.from(actual, 'base64url');
+    const expectedBuffer = Buffer.from(expected, 'base64url');
+    return (
+      actualBuffer.length === expectedBuffer.length &&
+      timingSafeEqual(actualBuffer, expectedBuffer)
+    );
+  } catch {
+    return false;
+  }
+}
+
+export function parseMaoyiAuthChallenge(
+  raw: string,
+  expectedAppId: string
+): MaoyiAuthChallenge | undefined {
+  if (Buffer.byteLength(raw, 'utf8') > maoyiControlMaxMessageBytes) {
+    return undefined;
+  }
+  try {
+    const value = JSON.parse(raw) as unknown;
+    if (
+      !isRecord(value) ||
+      !hasOnlyKeys(value, ['type', 'appId', 'challenge']) ||
+      value.type !== 'auth.challenge' ||
+      value.appId !== expectedAppId ||
+      typeof value.challenge !== 'string' ||
+      !/^[A-Za-z0-9_-]{43}$/.test(value.challenge) ||
+      Buffer.from(value.challenge, 'base64url').length !== 32
+    ) {
+      return undefined;
+    }
+    return {
+      type: 'auth.challenge',
+      appId: value.appId,
+      challenge: value.challenge,
+    };
+  } catch {
+    return undefined;
+  }
+}
+
+export function createMaoyiAuthResponse(
+  key: Buffer<ArrayBuffer>,
+  appId: string,
+  processId: number,
+  challenge: string
+): string {
+  return JSON.stringify({
+    type: 'auth.response',
+    processId,
+    mac: controlMac(key, [
+      'maoyi-signal-control-auth-v1',
+      appId,
+      processId,
+      challenge,
+    ]),
+  });
+}
+
+export function createMaoyiSignalEnvelope(
+  key: Buffer<ArrayBuffer>,
+  appId: string,
+  processId: number,
+  sequence: number,
+  event: MaoyiControlEvent,
+  now = Date.now()
+): string {
+  const payload: MaoyiControlPayload<MaoyiControlEvent> = {
+    appId,
+    at: now,
+    ...event,
+  };
+  const envelope: MaoyiControlEnvelope<typeof payload> = {
+    version: maoyiControlProtocolVersion,
+    sequence,
+    payload,
+    mac: controlMac(key, [
+      'maoyi-signal-control-message-v1',
+      'signal-to-main',
+      appId,
+      processId,
+      sequence,
+      payload,
+    ]),
+  };
+  return JSON.stringify(envelope);
+}
+
+export function verifyMaoyiLauncherEnvelope(
+  raw: string,
+  key: Buffer<ArrayBuffer>,
+  appId: string,
+  processId: number,
+  expectedSequence: number
+): MaoyiControlCommand | undefined {
+  if (Buffer.byteLength(raw, 'utf8') > maoyiControlMaxMessageBytes) {
+    return undefined;
+  }
+  try {
+    const envelope = JSON.parse(raw) as unknown;
+    if (
+      !isRecord(envelope) ||
+      !hasOnlyKeys(envelope, ['version', 'sequence', 'payload', 'mac']) ||
+      envelope.version !== maoyiControlProtocolVersion ||
+      envelope.sequence !== expectedSequence
+    ) {
+      return undefined;
+    }
+    const command = parseMaoyiControlCommand(envelope.payload);
+    if (!command) {
+      return undefined;
+    }
+    const expectedMac = controlMac(key, [
+      'maoyi-signal-control-message-v1',
+      'main-to-signal',
+      appId,
+      processId,
+      expectedSequence,
+      envelope.payload,
+    ]);
+    return constantTimeBase64UrlEqual(envelope.mac, expectedMac)
+      ? command
+      : undefined;
+  } catch {
+    return undefined;
+  }
+}
