+Napi::Value SetWindowOwner(const Napi::CallbackInfo& info) {
+  auto env = info.Env();
+  if (info.Length() != 3 || !info[0].IsBuffer() || !info[1].IsBuffer() ||
+      !info[2].IsNumber()) {
+    Napi::TypeError::New(
+        env,
+        "Expected child handle, owner handle, and owner process identifier")
+        .ThrowAsJavaScriptException();
+    return env.Undefined();
+  }
+
+  auto child_buffer = info[0].As<Napi::Buffer<uint8_t>>();
+  auto owner_buffer = info[1].As<Napi::Buffer<uint8_t>>();
+  if (child_buffer.Length() != sizeof(uintptr_t) ||
+      owner_buffer.Length() != sizeof(uintptr_t)) {
+    Napi::TypeError::New(env, "Window handles have an invalid size")
+        .ThrowAsJavaScriptException();
+    return env.Undefined();
+  }
+
+  uintptr_t child_value = 0;
+  uintptr_t owner_value = 0;
+  memcpy(&child_value, child_buffer.Data(), sizeof(child_value));
+  memcpy(&owner_value, owner_buffer.Data(), sizeof(owner_value));
+  auto child = reinterpret_cast<HWND>(child_value);
+  auto owner = reinterpret_cast<HWND>(owner_value);
+  if (!IsWindow(child) || !IsWindow(owner)) {
+    Napi::Error::New(env, "A window handle is no longer valid")
+        .ThrowAsJavaScriptException();
+    return env.Undefined();
+  }
+
+  DWORD child_process_id = 0;
+  DWORD owner_process_id = 0;
+  DWORD child_session_id = 0;
+  DWORD owner_session_id = 0;
+  GetWindowThreadProcessId(child, &child_process_id);
+  GetWindowThreadProcessId(owner, &owner_process_id);
+  auto expected_owner_process_id = info[2].As<Napi::Number>().Uint32Value();
+  if (child_process_id != GetCurrentProcessId() || owner_process_id == 0 ||
+      owner_process_id != expected_owner_process_id ||
+      GetAncestor(owner, GA_ROOT) != owner ||
+      !ProcessIdToSessionId(child_process_id, &child_session_id) ||
+      !ProcessIdToSessionId(owner_process_id, &owner_session_id) ||
+      child_session_id != owner_session_id) {
+    Napi::Error::New(env, "Window ownership validation failed")
+        .ThrowAsJavaScriptException();
+    return env.Undefined();
+  }
+
+  SetLastError(ERROR_SUCCESS);
+  auto previous = SetWindowLongPtrW(
+      child, GWLP_HWNDPARENT, reinterpret_cast<LONG_PTR>(owner));
+  auto last_error = GetLastError();
+  if ((previous == 0 && last_error != ERROR_SUCCESS) ||
+      GetWindow(child, GW_OWNER) != owner) {
+    Napi::Error::New(env, "Windows rejected the owner relationship")
+        .ThrowAsJavaScriptException();
+    return env.Undefined();
+  }
+  SetWindowPos(child, nullptr, 0, 0, 0, 0,
+               SWP_NOMOVE | SWP_NOSIZE | SWP_NOZORDER | SWP_NOACTIVATE |
+                   SWP_FRAMECHANGED);
+
+  return Napi::Boolean::New(env, true);
+}
