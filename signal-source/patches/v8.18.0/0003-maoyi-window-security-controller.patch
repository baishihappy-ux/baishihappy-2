diff --git a/app/maoyi/windowController.main.ts b/app/maoyi/windowController.main.ts
new file mode 100644
index 0000000000000000000000000000000000000000..3e410868e78ab7ba44cedbd6a669b44613241aa7
--- /dev/null
+++ b/app/maoyi/windowController.main.ts
@@ -0,0 +1,546 @@
+// Copyright 2026 Signal Messenger, LLC
+// SPDX-License-Identifier: AGPL-3.0-only
+
+import { app, type BrowserWindow } from 'electron';
+
+import {
+  getMaoyiControlBridge,
+  type MaoyiControlBridge,
+} from './controlBridge.main.ts';
+import type {
+  MaoyiControlCommand,
+  MaoyiWindowBounds,
+} from './controlProtocol.node.ts';
+import {
+  applyMaoyiWindowOwner,
+  type MaoyiOwnerDescriptor,
+} from './windowsOwner.node.ts';
+
+const windowControllerKey = Symbol.for('maoyi.signal.window-controller.v1');
+
+type GuardedWindowMethods = Readonly<{
+  show: () => void;
+  showInactive: () => void;
+  focus: () => void;
+  restore: () => void;
+  maximize: () => void;
+  hide: () => void;
+}>;
+
+type ProtocolHandler = (url: string) => void;
+
+export type MaoyiWindowController = Readonly<{
+  attachMainWindow: (window: BrowserWindow) => void;
+  markRuntimeReady: () => void;
+  setProtocolHandler: (handler: ProtocolHandler) => void;
+  canExposeWindows: () => boolean;
+  stop: () => void;
+}>;
+
+function sameBounds(
+  left: MaoyiWindowBounds | undefined,
+  right: MaoyiWindowBounds
+): boolean {
+  return Boolean(
+    left &&
+    left.x === right.x &&
+    left.y === right.y &&
+    left.width === right.width &&
+    left.height === right.height
+  );
+}
+
+function safeErrorMessage(error: unknown): string {
+  const message = error instanceof Error ? error.message : String(error);
+  return message.slice(0, 512) || 'Signal control operation failed';
+}
+
+export function getMaoyiWindowController():
+  | MaoyiWindowController
+  | undefined {
+  return Reflect.get(globalThis, windowControllerKey) as
+    | MaoyiWindowController
+    | undefined;
+}
+
+export function startMaoyiWindowController(
+  bridgeArgument?: MaoyiControlBridge
+): MaoyiWindowController {
+  const existing = getMaoyiWindowController();
+  if (existing) {
+    return existing;
+  }
+  const bridge = bridgeArgument ?? getMaoyiControlBridge();
+  if (!bridge) {
+    throw new Error('Maoyi control bridge is unavailable');
+  }
+
+  const windows = new Set<BrowserWindow>();
+  const guardedMethods = new WeakMap<BrowserWindow, GuardedWindowMethods>();
+  const pendingProtocolUrls: Array<string> = [];
+  let mainWindow: BrowserWindow | undefined;
+  let pendingBounds: MaoyiWindowBounds | undefined;
+  let ownerDescriptor: MaoyiOwnerDescriptor | undefined;
+  let ownerAttached = false;
+  let securityLocked = true;
+  let visibilityRevision = -1;
+  let desiredVisible = false;
+  let runtimeReady = false;
+  let transportAuthenticated = false;
+  let protocolHandler: ProtocolHandler | undefined;
+  let activeScriptCount = 0;
+  let scriptGeneration = 0;
+  let pendingLockAcknowledgement = false;
+  let stopped = false;
+
+  const canExposeWindows = (): boolean =>
+    Boolean(
+      !stopped &&
+      transportAuthenticated &&
+      runtimeReady &&
+      !securityLocked &&
+      ownerAttached &&
+      desiredVisible &&
+      mainWindow &&
+      !mainWindow.isDestroyed()
+    );
+
+  const rawHide = (window: BrowserWindow): void => {
+    if (window.isDestroyed()) {
+      return;
+    }
+    try {
+      guardedMethods.get(window)?.hide();
+    } catch {
+      // A destroyed native window is already hidden from the user.
+    }
+  };
+
+  const hideAllWindows = (): void => {
+    for (const window of windows) {
+      rawHide(window);
+    }
+  };
+
+  const visibleWindowCount = (): number => {
+    let count = 0;
+    for (const window of windows) {
+      if (!window.isDestroyed() && window.isVisible()) {
+        count += 1;
+      }
+    }
+    return count;
+  };
+
+  const sendWindowState = (): void => {
+    if (!mainWindow || mainWindow.isDestroyed()) {
+      bridge.send({ type: 'window.state', visible: false });
+      return;
+    }
+    const bounds = mainWindow.getBounds();
+    const visible = mainWindow.isVisible() && canExposeWindows();
+    bridge.send({ type: 'window.state', visible, bounds });
+  };
+
+  const sendVisibilityApplied = (): void => {
+    if (securityLocked && activeScriptCount > 0) {
+      pendingLockAcknowledgement = true;
+      return;
+    }
+    pendingLockAcknowledgement = false;
+    bridge.send({
+      type: 'security.visibility-applied',
+      locked: securityLocked,
+      revision: Math.max(0, visibilityRevision),
+      visibleWindowCount: visibleWindowCount(),
+    });
+  };
+
+  const applyBounds = (bounds: MaoyiWindowBounds): void => {
+    pendingBounds = bounds;
+    if (!mainWindow || mainWindow.isDestroyed()) {
+      return;
+    }
+    const current = mainWindow.getBounds();
+    if (sameBounds(current, bounds)) {
+      return;
+    }
+    if (mainWindow.isMaximized()) {
+      mainWindow.unmaximize();
+    }
+    mainWindow.setBounds(bounds, false);
+  };
+
+  const attachOwnerToWindow = (window: BrowserWindow): boolean => {
+    if (!ownerDescriptor || window.isDestroyed()) {
+      return false;
+    }
+    const parent = window.getParentWindow();
+    if (parent && parent !== window) {
+      return true;
+    }
+    return applyMaoyiWindowOwner(window, ownerDescriptor);
+  };
+
+  const applyOwner = (): void => {
+    ownerAttached = false;
+    hideAllWindows();
+    if (!mainWindow || mainWindow.isDestroyed() || !ownerDescriptor) {
+      return;
+    }
+    try {
+      ownerAttached = attachOwnerToWindow(mainWindow);
+      if (!ownerAttached) {
+        bridge.send({ type: 'transport.error', code: 'owner-rejected' });
+        return;
+      }
+      for (const window of windows) {
+        if (window !== mainWindow) {
+          attachOwnerToWindow(window);
+        }
+      }
+      bridge.send({
+        type: 'window.owner-attached',
+        ownerProcessId: ownerDescriptor.ownerProcessId,
+      });
+    } catch {
+      ownerAttached = false;
+      bridge.send({ type: 'transport.error', code: 'owner-rejected' });
+    }
+  };
+
+  const showMainWindow = (): void => {
+    if (!canExposeWindows() || !mainWindow || mainWindow.isDestroyed()) {
+      hideAllWindows();
+      return;
+    }
+    if (pendingBounds) {
+      applyBounds(pendingBounds);
+    }
+    if (!mainWindow.isVisible()) {
+      guardedMethods.get(mainWindow)?.show();
+    }
+  };
+
+  const guardWindow = (window: BrowserWindow): void => {
+    if (guardedMethods.has(window)) {
+      return;
+    }
+    const originals: GuardedWindowMethods = {
+      show: window.show.bind(window),
+      showInactive: window.showInactive.bind(window),
+      focus: window.focus.bind(window),
+      restore: window.restore.bind(window),
+      maximize: window.maximize.bind(window),
+      hide: window.hide.bind(window),
+    };
+    guardedMethods.set(window, originals);
+    windows.add(window);
+
+    const hideWhenBlocked = (): void => {
+      if (!canExposeWindows()) {
+        rawHide(window);
+      }
+    };
+    Object.defineProperties(window, {
+      show: {
+        configurable: true,
+        value: () => {
+          if (canExposeWindows()) originals.show();
+          else originals.hide();
+        },
+      },
+      showInactive: {
+        configurable: true,
+        value: () => {
+          if (canExposeWindows()) originals.showInactive();
+          else originals.hide();
+        },
+      },
+      focus: {
+        configurable: true,
+        value: () => {
+          if (canExposeWindows()) originals.focus();
+          else originals.hide();
+        },
+      },
+      restore: {
+        configurable: true,
+        value: () => {
+          if (canExposeWindows()) originals.restore();
+          else originals.hide();
+        },
+      },
+      maximize: {
+        configurable: true,
+        value: () => {
+          if (canExposeWindows()) originals.maximize();
+        },
+      },
+    });
+
+    window.on('show', () => {
+      hideWhenBlocked();
+      bridge.send({
+        type: 'window.visibility-changed',
+        visible: window.isVisible() && canExposeWindows(),
+      });
+      sendWindowState();
+    });
+    window.on('hide', () => {
+      bridge.send({ type: 'window.visibility-changed', visible: false });
+      sendWindowState();
+    });
+    window.on('focus', () => {
+      if (canExposeWindows()) {
+        bridge.send({ type: 'window.group-focused' });
+      } else {
+        rawHide(window);
+      }
+    });
+    window.on('blur', () => {
+      bridge.send({ type: 'window.group-blurred' });
+    });
+    window.on('closed', () => {
+      windows.delete(window);
+      if (mainWindow === window) {
+        mainWindow = undefined;
+        ownerAttached = false;
+        desiredVisible = false;
+        bridge.send({ type: 'window.closed' });
+        bridge.send({ type: 'closed' });
+      }
+    });
+    if (window.isVisible()) {
+      rawHide(window);
+    }
+  };
+
+  const sendBounds = (): void => {
+    if (!mainWindow || mainWindow.isDestroyed()) {
+      return;
+    }
+    const bounds = mainWindow.getBounds();
+    bridge.send({ type: 'window.bounds-changed', bounds });
+    bridge.send({ type: 'window.bounds', bounds });
+  };
+
+  const runProtocolHandler = (url: string, requestId?: string): void => {
+    if (securityLocked || !runtimeReady || !protocolHandler) {
+      bridge.send({
+        type: 'error',
+        requestId,
+        message: 'Signal protocol handling is unavailable while locked',
+      });
+      return;
+    }
+    try {
+      protocolHandler(url);
+      bridge.send({ type: 'protocol.opened', requestId });
+    } catch (error) {
+      bridge.send({
+        type: 'error',
+        requestId,
+        message: safeErrorMessage(error),
+      });
+    }
+  };
+
+  const executeScript = async (
+    command: Extract<MaoyiControlCommand, { type: 'script.execute' }>
+  ): Promise<void> => {
+    if (
+      securityLocked ||
+      !runtimeReady ||
+      !mainWindow ||
+      mainWindow.isDestroyed()
+    ) {
+      bridge.send({
+        type: 'error',
+        requestId: command.requestId,
+        message: 'Signal script execution is unavailable while locked',
+      });
+      return;
+    }
+    const generation = scriptGeneration;
+    activeScriptCount += 1;
+    try {
+      const result = await mainWindow.webContents.executeJavaScript(
+        command.script,
+        true
+      );
+      if (generation === scriptGeneration && !securityLocked) {
+        bridge.send({
+          type: 'script.result',
+          requestId: command.requestId,
+          result,
+        });
+      }
+    } catch (error) {
+      if (generation === scriptGeneration) {
+        bridge.send({
+          type: 'error',
+          requestId: command.requestId,
+          message: safeErrorMessage(error),
+        });
+      }
+    } finally {
+      activeScriptCount = Math.max(0, activeScriptCount - 1);
+      if (pendingLockAcknowledgement) {
+        sendVisibilityApplied();
+      }
+    }
+  };
+
+  const handleCommand = (command: MaoyiControlCommand): void => {
+    switch (command.type) {
+      case 'hello':
+        if (runtimeReady) {
+          bridge.send({ type: 'ready' });
+          sendWindowState();
+        }
+        return;
+      case 'heartbeat.ack':
+        return;
+      case 'security.visibility':
+        if (command.locked) {
+          visibilityRevision = Math.max(visibilityRevision, command.revision);
+          securityLocked = true;
+          desiredVisible = false;
+          scriptGeneration += 1;
+          hideAllWindows();
+          sendVisibilityApplied();
+          return;
+        }
+        if (command.revision > visibilityRevision) {
+          visibilityRevision = command.revision;
+          securityLocked = false;
+        }
+        sendVisibilityApplied();
+        return;
+      case 'window.owner':
+        ownerDescriptor = {
+          handle: command.handle,
+          ownerProcessId: command.ownerProcessId,
+        };
+        applyOwner();
+        return;
+      case 'window.bounds-changed':
+        applyBounds(command.bounds);
+        return;
+      case 'window.show':
+        if (command.bounds) {
+          applyBounds(command.bounds);
+        }
+        if (securityLocked || !ownerAttached) {
+          desiredVisible = false;
+          hideAllWindows();
+          return;
+        }
+        desiredVisible = true;
+        showMainWindow();
+        return;
+      case 'window.focus':
+        if (canExposeWindows() && mainWindow && !mainWindow.isDestroyed()) {
+          guardedMethods.get(mainWindow)?.focus();
+        }
+        return;
+      case 'window.hide':
+        desiredVisible = false;
+        hideAllWindows();
+        return;
+      case 'protocol.open':
+        runProtocolHandler(command.url, command.requestId);
+        return;
+      case 'script.execute':
+        void executeScript(command);
+        return;
+      case 'shutdown':
+        desiredVisible = false;
+        securityLocked = true;
+        hideAllWindows();
+        bridge.send({ type: 'shutdown.ack' });
+        app.quit();
+        return;
+      default:
+        return;
+    }
+  };
+
+  const removeCommandHandler = bridge.onCommand(handleCommand);
+  const removeTransportHandler = bridge.onTransportState(authenticated => {
+    transportAuthenticated = authenticated;
+    if (!authenticated) {
+      securityLocked = true;
+      visibilityRevision = -1;
+      desiredVisible = false;
+      scriptGeneration += 1;
+      hideAllWindows();
+    }
+  });
+  bridge.setHeartbeatVisibleProvider(
+    () => Boolean(mainWindow?.isVisible()) && canExposeWindows()
+  );
+
+  const onBrowserWindowCreated = (
+    _event: Electron.Event,
+    window: BrowserWindow
+  ): void => {
+    try {
+      guardWindow(window);
+      if (ownerDescriptor) {
+        attachOwnerToWindow(window);
+      }
+    } catch {
+      rawHide(window);
+      bridge.send({ type: 'transport.error', code: 'window-guard-failed' });
+    }
+  };
+  app.on('browser-window-created', onBrowserWindowCreated);
+
+  const controller: MaoyiWindowController = Object.freeze({
+    attachMainWindow(window: BrowserWindow) {
+      mainWindow = window;
+      guardWindow(window);
+      rawHide(window);
+      if (pendingBounds) {
+        applyBounds(pendingBounds);
+      }
+      if (ownerDescriptor) {
+        applyOwner();
+      }
+      window.on('move', sendBounds);
+      window.on('resize', sendBounds);
+    },
+    markRuntimeReady() {
+      runtimeReady = true;
+      bridge.send({ type: 'ready' });
+      sendWindowState();
+      while (pendingProtocolUrls.length > 0 && protocolHandler) {
+        const url = pendingProtocolUrls.shift();
+        if (url) runProtocolHandler(url);
+      }
+      showMainWindow();
+    },
+    setProtocolHandler(handler: ProtocolHandler) {
+      protocolHandler = handler;
+    },
+    canExposeWindows,
+    stop() {
+      if (stopped) {
+        return;
+      }
+      stopped = true;
+      securityLocked = true;
+      desiredVisible = false;
+      hideAllWindows();
+      removeCommandHandler();
+      removeTransportHandler();
+      app.off('browser-window-created', onBrowserWindowCreated);
+      bridge.setHeartbeatVisibleProvider(() => false);
+      Reflect.deleteProperty(globalThis, windowControllerKey);
+    },
+  });
+  Reflect.set(globalThis, windowControllerKey, controller);
+  return controller;
+}
