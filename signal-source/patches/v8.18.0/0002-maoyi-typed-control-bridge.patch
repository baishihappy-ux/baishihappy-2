new file mode 100644
index 0000000000000000000000000000000000000000..432fea7dd7152d9a47e33c49c60496280662f572
--- /dev/null
+++ b/app/maoyi/controlBridge.main.ts
@@ -0,0 +1,222 @@
+// SPDX-License-Identifier: AGPL-3.0-only
+
+import {
+  createMaoyiAuthResponse,
+  createMaoyiSignalEnvelope,
+  maoyiControlHeartbeatMs,
+  maoyiControlMaxMessageBytes,
+  maoyiControlReconnectMs,
+  parseMaoyiAuthChallenge,
+  verifyMaoyiLauncherEnvelope,
+  type MaoyiControlCommand,
+  type MaoyiControlEvent,
+} from './controlProtocol.main.ts';
+import { takeMaoyiLaunchContext } from './launchContext.main.ts';
+
+const controlBridgeKey = Symbol.for('maoyi.signal.control-bridge.v1');
+
+export type MaoyiControlBridge = Readonly<{
+  onCommand: (handler: (command: MaoyiControlCommand) => void) => () => void;
+  send: (event: MaoyiControlEvent) => boolean;
+  stop: () => void;
+}>;
+
+function schedule(
+  callback: () => void,
+  delay: number
+): ReturnType<typeof setTimeout> {
+  const timer = setTimeout(callback, delay);
+  timer.unref();
+  return timer;
+}
+
+export function getMaoyiControlBridge(): MaoyiControlBridge | undefined {
+  return Reflect.get(globalThis, controlBridgeKey) as
+    | MaoyiControlBridge
+    | undefined;
+}
+
+export function startMaoyiControlBridge(): MaoyiControlBridge {
+  const existing = getMaoyiControlBridge();
+  if (existing) {
+    return existing;
+  }
+
+  const launchContext = takeMaoyiLaunchContext();
+  if (!launchContext || launchContext.controlKey.length !== 32) {
+    throw new Error('Maoyi launch context is unavailable');
+  }
+  const context = launchContext;
+
+  const controlKey = Buffer.from(context.controlKey);
+  context.controlKey.fill(0);
+  const handlers = new Set<(command: MaoyiControlCommand) => void>();
+  let socket: WebSocket | undefined;
+  let reconnectTimer: ReturnType<typeof setTimeout> | undefined;
+  let heartbeatTimer: ReturnType<typeof setInterval> | undefined;
+  let authenticated = false;
+  let stopped = false;
+  let sendSequence = 0;
+  let receiveSequence = 0;
+
+  const clearTimers = (): void => {
+    if (reconnectTimer) {
+      clearTimeout(reconnectTimer);
+      reconnectTimer = undefined;
+    }
+    if (heartbeatTimer) {
+      clearInterval(heartbeatTimer);
+      heartbeatTimer = undefined;
+    }
+  };
+
+  const send = (event: MaoyiControlEvent): boolean => {
+    if (!authenticated || !socket || socket.readyState !== WebSocket.OPEN) {
+      return false;
+    }
+    sendSequence += 1;
+    socket.send(
+      createMaoyiSignalEnvelope(
+        controlKey,
+        context.appId,
+        process.pid,
+        sendSequence,
+        event
+      )
+    );
+    return true;
+  };
+
+  const stop = (): void => {
+    if (stopped) {
+      return;
+    }
+    stopped = true;
+    authenticated = false;
+    clearTimers();
+    try {
+      socket?.close();
+    } catch {
+      // A closing transport is already stopped.
+    }
+    socket = undefined;
+    handlers.clear();
+    controlKey.fill(0);
+    Reflect.deleteProperty(globalThis, controlBridgeKey);
+  };
+
+  function scheduleReconnect(): void {
+    if (stopped || reconnectTimer) {
+      return;
+    }
+    reconnectTimer = schedule(() => {
+      reconnectTimer = undefined;
+      connect();
+    }, maoyiControlReconnectMs);
+  }
+
+  function connect(): void {
+    if (stopped) {
+      return;
+    }
+    authenticated = false;
+    sendSequence = 0;
+    receiveSequence = 0;
+    if (heartbeatTimer) {
+      clearInterval(heartbeatTimer);
+      heartbeatTimer = undefined;
+    }
+
+    try {
+      socket = new WebSocket(
+        `ws://127.0.0.1:${context.wsPort}?appId=${encodeURIComponent(context.appId)}`
+      );
+    } catch {
+      scheduleReconnect();
+      return;
+    }
+
+    socket.addEventListener('message', event => {
+      if (
+        stopped ||
+        typeof event.data !== 'string' ||
+        Buffer.byteLength(event.data, 'utf8') > maoyiControlMaxMessageBytes
+      ) {
+        socket?.close();
+        return;
+      }
+
+      if (!authenticated) {
+        const challenge = parseMaoyiAuthChallenge(event.data, context.appId);
+        if (!challenge) {
+          socket?.close();
+          return;
+        }
+        socket?.send(
+          createMaoyiAuthResponse(
+            controlKey,
+            context.appId,
+            process.pid,
+            challenge.challenge
+          )
+        );
+        authenticated = true;
+        send({ type: 'ready', title: context.title || undefined });
+        heartbeatTimer = setInterval(() => {
+          send({ type: 'heartbeat', visible: false });
+        }, maoyiControlHeartbeatMs);
+        heartbeatTimer.unref();
+        return;
+      }
+
+      const expectedSequence = receiveSequence + 1;
+      const command = verifyMaoyiLauncherEnvelope(
+        event.data,
+        controlKey,
+        context.appId,
+        process.pid,
+        expectedSequence
+      );
+      if (
+        !command ||
+        (command.type === 'hello' && command.appId !== context.appId)
+      ) {
+        socket?.close();
+        return;
+      }
+      receiveSequence = expectedSequence;
+      for (const handler of handlers) {
+        try {
+          handler(command);
+        } catch {
+          // One command consumer cannot weaken or stop the authenticated bridge.
+        }
+      }
+    });
+    socket.addEventListener('close', () => {
+      authenticated = false;
+      if (heartbeatTimer) {
+        clearInterval(heartbeatTimer);
+        heartbeatTimer = undefined;
+      }
+      scheduleReconnect();
+    });
+    socket.addEventListener('error', () => {
+      // The close event performs the bounded reconnect.
+    });
+  }
+
+  const bridge: MaoyiControlBridge = Object.freeze({
+    onCommand(handler: (command: MaoyiControlCommand) => void) {
+      handlers.add(handler);
+      return () => {
+        handlers.delete(handler);
+      };
+    },
+    send,
+    stop,
+  });
+  Reflect.set(globalThis, controlBridgeKey, bridge);
+  connect();
+  return bridge;
+}
