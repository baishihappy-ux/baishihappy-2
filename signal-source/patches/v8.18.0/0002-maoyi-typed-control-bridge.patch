diff --git a/ts/test-node/maoyi/controlProtocol_test.node.ts b/ts/test-node/maoyi/controlProtocol_test.node.ts
new file mode 100644
index 0000000000000000000000000000000000000000..0b2c3b7d6d7c299fe61ce1f1a3976db0e5bd156e
--- /dev/null
+++ b/ts/test-node/maoyi/controlProtocol_test.node.ts
@@ -0,0 +1,153 @@
+// SPDX-License-Identifier: AGPL-3.0-only
+
+import assert from 'node:assert/strict';
+import { createHmac, randomBytes } from 'node:crypto';
+
+import {
+  createMaoyiAuthResponse,
+  createMaoyiSignalEnvelope,
+  parseMaoyiAuthChallenge,
+  parseMaoyiControlCommand,
+  verifyMaoyiLauncherEnvelope,
+} from '../../../app/maoyi/controlProtocol.main.ts';
+
+describe('Maoyi typed control protocol', () => {
+  const appId = 'Signal-00000000-0000-4000-8000-000000000001';
+  const processId = 4242;
+  const key = Buffer.alloc(32, 7);
+
+  it('accepts only whitelisted bounded commands', () => {
+    assert.deepEqual(
+      parseMaoyiControlCommand({
+        type: 'window.bounds-changed',
+        bounds: { x: 10, y: 20, width: 800, height: 600 },
+      }),
+      {
+        type: 'window.bounds-changed',
+        bounds: { x: 10, y: 20, width: 800, height: 600 },
+      }
+    );
+    assert.equal(
+      parseMaoyiControlCommand({
+        type: 'window.bounds-changed',
+        bounds: { x: 10.5, y: 20, width: 800, height: 600 },
+      }),
+      undefined
+    );
+    assert.equal(
+      parseMaoyiControlCommand({ type: 'window.hide', extra: true }),
+      undefined
+    );
+    assert.equal(
+      parseMaoyiControlCommand({ type: 'unknown.command' }),
+      undefined
+    );
+    assert.equal(
+      parseMaoyiControlCommand({
+        type: 'script.execute',
+        requestId: 'request',
+        script: 'x'.repeat(900 * 1024 + 1),
+      }),
+      undefined
+    );
+  });
+
+  it('binds authentication to app id, process id, and challenge', () => {
+    const challenge = randomBytes(32).toString('base64url');
+    const parsed = parseMaoyiAuthChallenge(
+      JSON.stringify({ type: 'auth.challenge', appId, challenge }),
+      appId
+    );
+    assert.deepEqual(parsed, { type: 'auth.challenge', appId, challenge });
+    assert.equal(
+      parseMaoyiAuthChallenge(
+        JSON.stringify({
+          type: 'auth.challenge',
+          appId: `${appId}-other`,
+          challenge,
+        }),
+        appId
+      ),
+      undefined
+    );
+    const response = JSON.parse(
+      createMaoyiAuthResponse(key, appId, processId, challenge)
+    ) as { mac: string };
+    const expectedMac = createHmac('sha256', key)
+      .update(
+        JSON.stringify([
+          'maoyi-signal-control-auth-v1',
+          appId,
+          processId,
+          challenge,
+        ])
+      )
+      .digest('base64url');
+    assert.equal(response.mac, expectedMac);
+  });
+
+  it('rejects tampering and replayed launcher envelopes', () => {
+    const payload = { type: 'window.hide' };
+    const sequence = 1;
+    const mac = createHmac('sha256', key)
+      .update(
+        JSON.stringify([
+          'maoyi-signal-control-message-v1',
+          'main-to-signal',
+          appId,
+          processId,
+          sequence,
+          payload,
+        ])
+      )
+      .digest('base64url');
+    const raw = JSON.stringify({ version: 1, sequence, payload, mac });
+    assert.deepEqual(
+      verifyMaoyiLauncherEnvelope(raw, key, appId, processId, 1),
+      payload
+    );
+    assert.equal(
+      verifyMaoyiLauncherEnvelope(raw, key, appId, processId, 2),
+      undefined
+    );
+    assert.equal(
+      verifyMaoyiLauncherEnvelope(
+        JSON.stringify({
+          version: 1,
+          sequence,
+          payload: { type: 'window.focus' },
+          mac,
+        }),
+        key,
+        appId,
+        processId,
+        1
+      ),
+      undefined
+    );
+
+    const signalEnvelope = JSON.parse(
+      createMaoyiSignalEnvelope(
+        key,
+        appId,
+        processId,
+        1,
+        { type: 'heartbeat', visible: false },
+        1_800_000_000_000
+      )
+    ) as { sequence: number; payload: unknown; mac: string };
+    const signalExpectedMac = createHmac('sha256', key)
+      .update(
+        JSON.stringify([
+          'maoyi-signal-control-message-v1',
+          'signal-to-main',
+          appId,
+          processId,
+          signalEnvelope.sequence,
+          signalEnvelope.payload,
+        ])
+      )
+      .digest('base64url');
+    assert.equal(signalEnvelope.mac, signalExpectedMac);
+  });
+});
