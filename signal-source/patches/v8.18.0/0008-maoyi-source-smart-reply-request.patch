diff --git a/ts/test-node/maoyi/smartReplyContext_test.node.ts b/ts/test-node/maoyi/smartReplyContext_test.node.ts
new file mode 100644
index 0000000..50e3c3a
--- /dev/null
+++ b/ts/test-node/maoyi/smartReplyContext_test.node.ts	
@@ -0,0 +1,72 @@
+// Copyright 2026 Signal Messenger, LLC
+// SPDX-License-Identifier: AGPL-3.0-only
+
+import assert from 'node:assert/strict';
+
+import {
+  isMaoyiSmartReplyTrigger,
+  selectMaoyiSmartReplyContext,
+} from '../../maoyi/smartReplyContext.std.ts';
+import {
+  projectMaoyiMessage,
+  type MaoyiMessageProjection,
+} from '../../maoyi/messageProjection.std.ts';
+
+const conversationId = '22222222-2222-4222-8222-222222222222';
+
+function projection(
+  index: number,
+  direction: 'incoming' | 'outgoing' = 'incoming'
+): MaoyiMessageProjection {
+  const hex = index.toString(16).padStart(8, '0');
+  const value = projectMaoyiMessage({
+    id: `${hex}-3333-7333-8333-333333333333`,
+    conversationId,
+    text: `English message ${index}`,
+    direction,
+    timestamp: 1_800_000_000_000 + index,
+  });
+  assert.ok(value);
+  return value;
+}
+
+describe('Maoyi smart reply context', () => {
+  it('selects at most eight canonical messages in original old-to-new order', () => {
+    const messages = Array.from({ length: 10 }, (_, index) =>
+      projection(index, index % 2 === 0 ? 'outgoing' : 'incoming')
+    );
+    const context = selectMaoyiSmartReplyContext(conversationId, messages);
+    assert.deepEqual(context, messages.slice(2));
+    const latest = messages[9];
+    const stale = messages[8];
+    assert.ok(latest);
+    assert.ok(stale);
+    assert.equal(isMaoyiSmartReplyTrigger(latest, context), true);
+    assert.equal(isMaoyiSmartReplyTrigger(stale, context), false);
+  });
+
+  it('does not expose a trigger when the latest valid message is outgoing', () => {
+    const messages = [projection(1, 'incoming'), projection(2, 'outgoing')];
+    assert.deepEqual(
+      selectMaoyiSmartReplyContext(conversationId, messages),
+      []
+    );
+  });
+
+  it('rejects duplicate identities and cross-conversation projections', () => {
+    const value = projection(1);
+    assert.deepEqual(
+      selectMaoyiSmartReplyContext(conversationId, [value, value]),
+      []
+    );
+    assert.deepEqual(
+      selectMaoyiSmartReplyContext(conversationId, [
+        {
+          ...projection(2),
+          conversationId: '44444444-4444-4444-8444-444444444444',
+        },
+      ]),
+      []
+    );
+  });
+});

