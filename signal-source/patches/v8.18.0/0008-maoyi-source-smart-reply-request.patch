+export class MaoyiSmartReplyRequestLedger {
+  readonly #entries = new Map<
+    string,
+    Readonly<{
+      conversationId: string;
+      trigger: SmartReplyRequest['messages'][number];
+      expiresAt: number;
+    }>
+  >();
+  readonly #now: () => number;
+  readonly #limit: number;
+  readonly #ttlMs: number;
+
+  constructor(
+    now: () => number = Date.now,
+    limit = maoyiRequestCorrelationLimit,
+    ttlMs = maoyiRequestCorrelationTtlMs
+  ) {
+    this.#now = now;
+    this.#limit = limit;
+    this.#ttlMs = ttlMs;
+  }
+
+  #prune(): void {
+    const now = this.#now();
+    for (const [requestId, entry] of this.#entries) {
+      if (entry.expiresAt <= now) {
+        this.#entries.delete(requestId);
+      }
+    }
+  }
+
+  begin(request: SmartReplyRequest): boolean {
+    this.#prune();
+    if (this.#entries.has(request.requestId)) {
+      return false;
+    }
+    const trigger = request.messages.at(-1);
+    if (!trigger || trigger.messageId !== request.triggerMessageId) {
+      return false;
+    }
+    while (this.#entries.size >= this.#limit) {
+      const oldest = this.#entries.keys().next();
+      if (oldest.done) {
+        return false;
+      }
+      this.#entries.delete(oldest.value);
+    }
+    this.#entries.set(request.requestId, {
+      conversationId: request.conversationId,
+      trigger,
+      expiresAt: this.#now() + this.#ttlMs,
+    });
+    return true;
+  }
+
+  acceptTerminal(result: SmartReplyTerminal): boolean {
+    this.#prune();
+    const entry = this.#entries.get(result.requestId);
+    if (
+      !entry ||
+      entry.conversationId !== result.conversationId ||
+      entry.trigger.conversationId !== result.trigger.conversationId ||
+      entry.trigger.messageId !== result.trigger.messageId ||
+      entry.trigger.sourceHash !== result.trigger.sourceHash ||
+      entry.trigger.sourceText !== result.trigger.sourceText ||
+      entry.trigger.direction !== result.trigger.direction ||
+      entry.trigger.timestamp !== result.trigger.timestamp
+    ) {
+      return false;
+    }
+    this.#entries.delete(result.requestId);
+    return true;
+  }
+
+  remove(requestId: string): void {
+    this.#entries.delete(requestId);
+  }
+
+  clear(): void {
+    this.#entries.clear();
+  }
+}
