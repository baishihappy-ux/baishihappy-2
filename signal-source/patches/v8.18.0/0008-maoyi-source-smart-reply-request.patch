+// Copyright 2026 Signal Messenger, LLC
+// SPDX-License-Identifier: AGPL-3.0-only
+
+type SmartReplyComposerWriter = (
+  conversationId: string,
+  english: string
+) => boolean;
+
+let activeWriter: SmartReplyComposerWriter | undefined;
+
+export function registerMaoyiSmartReplyComposerWriter(
+  writer: SmartReplyComposerWriter
+): () => void {
+  activeWriter = writer;
+  return () => {
+    if (activeWriter === writer) {
+      activeWriter = undefined;
+    }
+  };
+}
+
+export function writeMaoyiSmartReplyToComposer(
+  conversationId: string,
+  english: string
+): boolean {
+  if (!english || english.length > 4_000) {
+    return false;
+  }
+  return activeWriter?.(conversationId, english) ?? false;
+}

diff --git a/ts/maoyi/smartReplyContext.std.ts b/ts/maoyi/smartReplyContext.std.ts
new file mode 100644
index 0000000..07eb05a
--- /dev/null
+++ b/ts/maoyi/smartReplyContext.std.ts	
@@ -0,0 +1,73 @@
+// Copyright 2026 Signal Messenger, LLC
+// SPDX-License-Identifier: AGPL-3.0-only
+
+import type { MaoyiMessageProjection } from './messageProjection.std.ts';
+
+export const maoyiSmartReplyContextVersion =
+  'df.signal.smart-reply-context.v1' as const;
+export const maoyiSmartReplyMaximumContextMessages = 8;
+
+export type MaoyiSmartReplySuggestionId = 'reply_1' | 'reply_2' | 'reply_3';
+
+export type MaoyiSmartReplySuggestion = Readonly<{
+  id: MaoyiSmartReplySuggestionId;
+  english: string;
+  chinese: string;
+}>;
+
+export type MaoyiSmartReplyErrorCode =
+  | 'unavailable'
+  | 'rate-limited'
+  | 'timeout'
+  | 'invalid-response'
+  | 'request-failed';
+
+function projectionsExactlyMatch(
+  left: MaoyiMessageProjection,
+  right: MaoyiMessageProjection
+): boolean {
+  return (
+    left.conversationId === right.conversationId &&
+    left.messageId === right.messageId &&
+    left.sourceHash === right.sourceHash &&
+    left.sourceText === right.sourceText &&
+    left.direction === right.direction &&
+    left.timestamp === right.timestamp
+  );
+}
+
+export function selectMaoyiSmartReplyContext(
+  conversationId: string,
+  messages: ReadonlyArray<MaoyiMessageProjection>
+): ReadonlyArray<MaoyiMessageProjection> {
+  const seen = new Set<string>();
+  for (const message of messages) {
+    const normalizedMessageId = message.messageId.toLowerCase();
+    if (
+      message.conversationId !== conversationId ||
+      seen.has(normalizedMessageId)
+    ) {
+      return [];
+    }
+    seen.add(normalizedMessageId);
+  }
+
+  const latest = messages.at(-1);
+  if (!latest || latest.direction !== 'incoming') {
+    return [];
+  }
+
+  return messages.slice(-maoyiSmartReplyMaximumContextMessages);
+}
+
+export function isMaoyiSmartReplyTrigger(
+  trigger: MaoyiMessageProjection,
+  context: ReadonlyArray<MaoyiMessageProjection>
+): boolean {
+  const latest = context.at(-1);
+  return Boolean(
+    latest &&
+    latest.direction === 'incoming' &&
+    projectionsExactlyMatch(latest, trigger)
+  );
+}

diff --git a/ts/maoyi/smartReplyRuntime.preload.ts b/ts/maoyi/smartReplyRuntime.preload.ts
new file mode 100644
index 0000000..835436a
--- /dev/null
+++ b/ts/maoyi/smartReplyRuntime.preload.ts	
@@ -0,0 +1,87 @@
+// Copyright 2026 Signal Messenger, LLC
+// SPDX-License-Identifier: AGPL-3.0-only
+
+// The runtime is deliberately preload-scoped because authenticated IPC owns it.
+// oxlint-disable-next-line signal-desktop/enforce-file-suffix
+import { useSyncExternalStore } from 'react';
+
+import type { MaoyiMessageProjection } from './messageProjection.std.ts';
+import type { MaoyiSmartReplySuggestion } from './smartReplyContext.std.ts';
+
+type SmartReplySnapshot = Readonly<{
+  trigger: MaoyiMessageProjection;
+  replies: ReadonlyArray<MaoyiSmartReplySuggestion>;
+}>;
+
+const emptyReplies: ReadonlyArray<MaoyiSmartReplySuggestion> = Object.freeze(
+  []
+);
+const listeners = new Set<() => void>();
+let snapshot: SmartReplySnapshot | undefined;
+
+function projectionsExactlyMatch(
+  left: MaoyiMessageProjection,
+  right: MaoyiMessageProjection
+): boolean {
+  return (
+    left.conversationId === right.conversationId &&
+    left.messageId === right.messageId &&
+    left.sourceHash === right.sourceHash &&
+    left.sourceText === right.sourceText &&
+    left.direction === right.direction &&
+    left.timestamp === right.timestamp
+  );
+}
+
+function emit(): void {
+  for (const listener of listeners) {
+    listener();
+  }
+}
+
+function subscribe(listener: () => void): () => void {
+  listeners.add(listener);
+  return () => listeners.delete(listener);
+}
+
+export function applyMaoyiSmartReplyResult(
+  trigger: MaoyiMessageProjection,
+  replies: ReadonlyArray<MaoyiSmartReplySuggestion>
+): void {
+  snapshot = Object.freeze({
+    trigger,
+    replies: Object.freeze(replies.map(reply => Object.freeze({ ...reply }))),
+  });
+  emit();
+}
+
+export function clearMaoyiSmartReplyRuntime(): void {
+  if (!snapshot) {
+    return;
+  }
+  snapshot = undefined;
+  emit();
+}
+
+export function getMaoyiSmartReplies(
+  trigger: MaoyiMessageProjection | undefined
+): ReadonlyArray<MaoyiSmartReplySuggestion> {
+  if (
+    !trigger ||
+    !snapshot ||
+    !projectionsExactlyMatch(trigger, snapshot.trigger)
+  ) {
+    return emptyReplies;
+  }
+  return snapshot.replies;
+}
+
+export function useMaoyiSmartReplies(
+  trigger: MaoyiMessageProjection | undefined
+): ReadonlyArray<MaoyiSmartReplySuggestion> {
+  return useSyncExternalStore(
+    subscribe,
+    () => getMaoyiSmartReplies(trigger),
+    () => emptyReplies
+  );
+}

