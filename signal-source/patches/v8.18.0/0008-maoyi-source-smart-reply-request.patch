@@ -0,0 +1,67 @@
+// Copyright 2026 Signal Messenger, LLC
+// SPDX-License-Identifier: AGPL-3.0-only
+
+import assert from 'node:assert/strict';
+import { readFileSync } from 'node:fs';
+
+function source(relativeUrl: string): string {
+  return readFileSync(new URL(relativeUrl, import.meta.url), 'utf8');
+}
+
+describe('Maoyi source smart reply contract', () => {
+  const message = source('../../components/conversation/Message.dom.tsx');
+  const smartTimeline = source('../../state/smart/Timeline.preload.tsx');
+  const smartTimelineItem = source(
+    '../../state/smart/TimelineItem.preload.tsx'
+  );
+  const rendererBridge = source('../../maoyi/messageBridge.preload.ts');
+  const composer = source('../../maoyi/smartReplyComposer.std.ts');
+  const protocol = source('../../../app/maoyi/controlProtocol.node.ts');
+
+  it('renders one native button only for the selected latest incoming projection', () => {
+    assert.match(message, /public renderMaoyiSmartReply\(\)/);
+    assert.match(message, />\s*智能回复\s*<\/button>/);
+    assert.match(
+      smartTimeline,
+      /selectMaoyiSmartReplyContext\([\s\S]*?projectMaoyiVisibleMessages\(id, items, messages\)/
+    );
+    assert.match(
+      smartTimelineItem,
+      /maoyiMessageProjection\?\.direction === 'incoming'[\s\S]*?maoyiMessageProjection\.messageId === maoyiSmartReplyMessageId/
+    );
+  });
+
+  it('sends a bounded old-to-new canonical context through the authenticated bridge', () => {
+    for (const value of [
+      message,
+      smartTimeline,
+      smartTimelineItem,
+      rendererBridge,
+    ]) {
+      assert.doesNotMatch(value, /MutationObserver|querySelectorAll\(/);
+    }
+    assert.match(rendererBridge, /type: 'smartReply\.request'/);
+    assert.match(
+      rendererBridge,
+      /contextVersion: maoyiSmartReplyContextVersion/
+    );
+    assert.match(rendererBridge, /messages: context/);
+    assert.match(protocol, /maoyiSmartReplyMaximumContextMessages/);
+    assert.match(protocol, /latest\.direction !== 'incoming'/);
+    assert.match(protocol, /latest\.messageId\.toLowerCase\(\)/);
+  });
+
+  it('renders three bilingual results and writes only English without sending', () => {
+    assert.match(message, /maoyiSmartReplySuggestions\.map\(reply/);
+    assert.match(message, /\{reply\.english\}/);
+    assert.match(message, /\{reply\.chinese\}/);
+    assert.match(
+      smartTimelineItem,
+      /writeMaoyiSmartReplyToComposer\(conversationId, english\)/
+    );
+    assert.match(rendererBridge, /type: 'smartReply\.result'/);
+    assert.match(rendererBridge, /type: 'smartReply\.error'/);
+    assert.match(rendererBridge, /applyMaoyiSmartReplyResult/);
+    assert.doesNotMatch(composer, /submit|sendMessage|sendMultiMediaMessage/);
+  });
+});
