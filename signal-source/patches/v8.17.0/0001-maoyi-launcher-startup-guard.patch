+// SPDX-License-Identifier: AGPL-3.0-only
+
+import { createRequire } from 'node:module';
+import { join } from 'node:path';
+import { app, dialog } from 'electron';
+
+import { runMaoyiStartupGuard } from './launchGuard.main.ts';
+
+try {
+  if (runMaoyiStartupGuard(app, dialog)) {
+    createRequire(__filename)(join(__dirname, 'signal-main.js'));
+  }
+} catch {
+  if (process.env.MAOYI_SIGNAL_GUARD_TEST_AUTOCLOSE !== '1') {
+    dialog.showErrorBox('MAOYI TRANSLATOR', '内置 Signal 启动校验失败');
+  }
+  app.exit(1);
+}
