+// SPDX-License-Identifier: AGPL-3.0-only
+
+import assert from 'node:assert/strict';
+import { createHash, generateKeyPairSync, sign } from 'node:crypto';
+import path from 'node:path';
+
+import {
+  deriveDataRoot,
+  isOwnedDataRoot,
+  scrubMaoyiArguments,
+  verifyInstanceBinding,
+  verifyLaunchCredential,
+  type SignalInstanceBinding,
+  type SignalLaunchCredential,
+} from '../../../app/maoyi/launchGuard.main.ts';
+
+describe('Maoyi launcher startup guard', () => {
+  const dataRoot = path.resolve('D:\\Fixture', 'MAOYI TRANSLATOR Data');
+  const profileId = '00000000-0000-4000-8000-000000000001';
+
+  it('only derives an application-owned root from a Signal instance path', () => {
+    assert.equal(isOwnedDataRoot(dataRoot), true);
+    assert.equal(
+      deriveDataRoot(
+        path.join(dataRoot, 'SignalInstances', `Signal-${profileId}`)
+      ),
+      dataRoot
+    );
+    assert.equal(deriveDataRoot(path.resolve('D:\\Fixture', 'Signal')), '');
+    assert.equal(isOwnedDataRoot(path.parse(dataRoot).root), false);
+  });
+
+  it('removes launcher-only arguments before Signal renderer configuration', () => {
+    const args = [
+      'Signal.exe',
+      '--df',
+      `--appId=Signal-${profileId}`,
+      '--wsPort=12345',
+      '--dfLaunchPipe=\\\\.\\pipe\\maoyi-signal-test',
+      '--windowMode=embed',
+      '--title=Profile One',
+      `--user-data-dir=${path.join(dataRoot, 'SignalInstances')}`,
+    ];
+    scrubMaoyiArguments(args);
+    assert.deepEqual(args, [
+      'Signal.exe',
+      `--user-data-dir=${path.join(dataRoot, 'SignalInstances')}`,
+    ]);
+  });
+
+  it('verifies profile and process-bound signed credentials', () => {
+    const { publicKey, privateKey } = generateKeyPairSync('ed25519');
+    const publicKeyPem = publicKey
+      .export({ type: 'spki', format: 'pem' })
+      .toString();
+    const runtimeBinding = {
+      schemaVersion: 1 as const,
+      productId: 'maoyi',
+      suiteId: '006-test-suite',
+      keyId: '006-test-key',
+      installationId: 'installation-test',
+      dataRootId: 'data-root-test',
+      machineCodeHash: createHash('sha256').update('machine').digest('hex'),
+      hardwareHash: createHash('sha256').update('hardware').digest('hex'),
+      devicePublicKeyPem: publicKeyPem,
+      createdAt: new Date().toISOString(),
+    };
+    const instanceUnsigned = {
+      schemaVersion: 1 as const,
+      productId: 'maoyi',
+      suiteId: runtimeBinding.suiteId,
+      installationId: runtimeBinding.installationId,
+      dataRootId: runtimeBinding.dataRootId,
+      profileId,
+      createdAt: new Date().toISOString(),
+    };
+    const instanceBinding: SignalInstanceBinding = {
+      ...instanceUnsigned,
+      signature: sign(
+        null,
+        Buffer.from(
+          JSON.stringify([
+            'maoyi-signal-instance-v1',
+            instanceUnsigned.schemaVersion,
+            instanceUnsigned.productId,
+            instanceUnsigned.suiteId,
+            instanceUnsigned.installationId,
+            instanceUnsigned.dataRootId,
+            instanceUnsigned.profileId,
+            instanceUnsigned.createdAt,
+          ])
+        ),
+        privateKey
+      ).toString('base64url'),
+    };
+    assert.equal(
+      verifyInstanceBinding(instanceBinding, runtimeBinding, profileId),
+      true
+    );
+    assert.equal(
+      verifyInstanceBinding(instanceBinding, runtimeBinding, `${profileId}0`),
+      false
+    );
+
+    const issuedAt = 1_800_000_000_000;
+    const launchUnsigned = {
+      schemaVersion: 1 as const,
+      productId: 'maoyi',
+      suiteId: runtimeBinding.suiteId,
+      installationId: runtimeBinding.installationId,
+      dataRootId: runtimeBinding.dataRootId,
+      profileId,
+      processId: 4242,
+      issuedAt,
+      expiresAt: issuedAt + 10_000,
+      nonce: Buffer.alloc(32, 1).toString('base64url'),
+      controlKey: Buffer.alloc(32, 2).toString('base64url'),
+    };
+    const credential: SignalLaunchCredential = {
+      ...launchUnsigned,
+      signature: sign(
+        null,
+        Buffer.from(
+          JSON.stringify([
+            'maoyi-signal-launch-v1',
+            launchUnsigned.schemaVersion,
+            launchUnsigned.productId,
+            launchUnsigned.suiteId,
+            launchUnsigned.installationId,
+            launchUnsigned.dataRootId,
+            launchUnsigned.profileId,
+            launchUnsigned.processId,
+            launchUnsigned.issuedAt,
+            launchUnsigned.expiresAt,
+            launchUnsigned.nonce,
+            launchUnsigned.controlKey,
+          ])
+        ),
+        privateKey
+      ).toString('base64url'),
+    };
+    const expectation = {
+      suiteId: runtimeBinding.suiteId,
+      installationId: runtimeBinding.installationId,
+      dataRootId: runtimeBinding.dataRootId,
+      profileId,
+      processId: launchUnsigned.processId,
+    };
+    assert.equal(
+      verifyLaunchCredential(
+        credential,
+        runtimeBinding,
+        expectation,
+        issuedAt + 5_000
+      ),
+      true
+    );
+    assert.equal(
+      verifyLaunchCredential(
+        credential,
+        runtimeBinding,
+        { ...expectation, processId: 4243 },
+        issuedAt + 5_000
+      ),
+      false
+    );
+    assert.equal(
+      verifyLaunchCredential(
+        credential,
+        runtimeBinding,
+        expectation,
+        issuedAt + 10_001
+      ),
+      false
+    );
+  });
+});
