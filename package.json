{
  "name": "maoyi",
  "productName": "maoyi",
  "version": "0.1.2",
  "private": true,
  "description": "maoyi international chat translation workspace.",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "vue-tsc --noEmit && vite build && tsc -p electron/tsconfig.json",
    "start": "electron .",
    "start:issuer": "npm run build && electron dist-electron/license-issuer.js",
    "start:prompt-generator": "npm run build && electron dist-electron/prompt-generator.js",
    "package:prompt-generator": "npm run build && electron-builder --config electron-builder.prompt-generator.cjs --win portable",
    "test:license-core": "npm run build && node tools/test-license-core.mjs",
    "test:runtime-security": "npm run build && node tools/test-runtime-security.mjs",
    "test:signal-control": "npm run build && node tools/patch-signal-control-channel.cjs --rebuild-from-backup && node tools/test-signal-control-channel.cjs",
    "test:signal-cache-response": "node tools/test-signal-cache-response-contract.cjs",
    "test:signal-live-translation": "node tools/test-signal-live-translation-queue.cjs",
    "test:signal-transitional-status": "node tools/test-signal-transitional-status.mjs",
    "test:signal-window-visibility": "node tools/test-signal-window-visibility-policy.mjs",
    "test:web-bubble-refresh-layout": "node tools/test-web-bubble-refresh-layout.mjs",
    "test:profile-tab-order": "node tools/test-profile-tab-order.mjs",
    "test:composer-question-mark": "node tools/test-composer-question-mark.mjs",
    "test:translation-sensitive-tokens": "node tools/test-translation-sensitive-tokens.mjs",
    "test:translation-prompt-bundle": "node tools/test-translation-prompt-bundle.mjs",
    "test:smart-reply": "node tools/test-smart-reply.mjs",
    "test:smart-reply:live": "node tools/test-smart-reply-live.mjs",
    "test:smart-reply-ui": "node tools/test-smart-reply-ui.mjs",
    "test:smart-reply-prompt-bundle": "node tools/test-smart-reply-prompt-bundle.mjs",
    "test:translation-english-style": "node tools/test-translation-english-style.mjs",
    "test:client-reauthorization": "node tools/test-client-reauthorization-contract.mjs",
    "test:issuer-suite-isolation": "node tools/test-issuer-suite-isolation.mjs",
    "test:prompt-generator-defaults": "node tools/test-prompt-generator-defaults.mjs",
    "test:browser-user-agent": "node tools/test-browser-user-agent.mjs",
    "test:signal-render-cache": "node tools/test-signal-render-cache-runtime.cjs",
    "test:signal-source-artifact": "node tools/test-signal-source-artifact.cjs",
    "test:signal-source-artifact:v8.18": "node tools/test-signal-source-artifact.cjs --version 8.18.0",
    "test:dev-runtime-sync": "node tools/sync-signal-source-runtime.cjs --check",
    "test:signal-source-compatibility": "node tools/test-signal-source-compatibility.cjs",
    "test:signal-source-compatibility:v8.18": "node tools/test-signal-source-compatibility.cjs --version 8.18.0",
    "test:signal-source-window-ui": "npm run build && node tools/test-signal-source-window-ui.cjs",
    "test:signal-source-window-ui:v8.18": "npm run build && node tools/test-signal-source-window-ui.cjs --version 8.18.0",
    "test:lock-screen-contract": "node tools/test-lock-screen-contract.cjs",
    "test:remote-guard": "node tools/test-remote-guard.mjs",
    "test:workspace-header-collapse": "node tools/test-workspace-header-collapse.mjs",
    "signal-source:check": "node tools/signal-source-experiment.cjs check",
    "signal-source:check:v8.18": "node tools/signal-source-experiment.cjs check --version 8.18.0",
    "signal-source:prepare": "node tools/signal-source-experiment.cjs prepare",
    "signal-source:prepare:v8.18": "node tools/signal-source-experiment.cjs prepare --version 8.18.0",
    "signal-source:verify": "node tools/signal-source-experiment.cjs verify",
    "signal-source:verify:v8.18": "node tools/signal-source-experiment.cjs verify --version 8.18.0",
    "signal-source:preflight": "node tools/signal-source-experiment.cjs preflight",
    "signal-source:preflight:v8.18": "node tools/signal-source-experiment.cjs preflight --version 8.18.0",
    "signal-source:build": "node tools/signal-source-experiment.cjs build",
    "signal-source:build:v8.18": "node tools/signal-source-experiment.cjs build --version 8.18.0",
    "test:electron-fuses": "node tools/test-electron-fuses.cjs",
    "test:electron-smoke": "npm run build && node tools/test-electron-smoke.cjs",
    "test:security": "npm run build && npm run security:check && npm run test:lock-screen-contract && npm run test:remote-guard && npm run test:workspace-header-collapse && npm run test:composer-question-mark && npm run test:translation-sensitive-tokens && npm run test:translation-prompt-bundle && npm run test:smart-reply && npm run test:smart-reply-ui && npm run test:smart-reply-prompt-bundle && npm run test:translation-english-style && npm run test:client-reauthorization && npm run test:issuer-suite-isolation && npm run test:prompt-generator-defaults && npm run test:browser-user-agent && npm run test:signal-cache-response && npm run test:signal-live-translation && npm run test:signal-transitional-status && npm run test:signal-window-visibility && npm run test:web-bubble-refresh-layout && npm run test:profile-tab-order && npm run test:signal-source-compatibility && npm run test:signal-source-compatibility:v8.18 && node tools/test-license-core.mjs && node tools/test-runtime-security.mjs && node tools/test-translation-cache-crypto.mjs && node tools/test-payment-address.mjs && node tools/test-sensitive-send-authorization.mjs && npm run test:electron-fuses",
    "build:smart-reply-prompt": "npm run build && node tools/build-smart-reply-prompt-bundle.mjs",
    "prepare:signal-runtime": "node tools/patch-signal-control-channel.cjs",
    "prepare:package-output": "node tools/prepare-package-output.cjs release",
    "prepare:package-signal-runtime": "node tools/prepare-package-signal-runtime.cjs",
    "suite:create": "node tools/create-license-suite.cjs",
    "suite:package": "node tools/package-license-suite.cjs",
    "prepare:client-suite": "node tools/prepare-client-license-suite.cjs",
    "security:check": "node tools/security-gate.cjs",
    "package:win": "npm run prepare:package-output && node tools/prepare-client-license-suite.cjs && npm run prepare:signal-runtime && npm run build && node tools/build-smart-reply-prompt-bundle.mjs && npm run prepare:package-signal-runtime && npm run security:check && electron-builder --win nsis && node tools/verify-packaged-output.cjs --client=release"
  },
  "devDependencies": {
    "@electron/asar": "^4.2.0",
    "@electron/fuses": "2.1.3",
    "@vitejs/plugin-vue": "6.0.7",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "electron": "43.1.0",
    "electron-builder": "26.15.3",
    "typescript": "^5.8.3",
    "vite": "8.1.4",
    "vue": "^3.5.17",
    "vue-tsc": "^2.2.10",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.maoyi.translator",
    "productName": "maoyi",
    "asar": true,
    "electronDist": "node_modules/electron/dist",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/main.js",
      "dist-electron/client-license.js",
      "dist-electron/license-core.js",
      "dist-electron/clone-reset.js",
      "dist-electron/runtime-security.js",
      "dist-electron/runtime-security-core.js",
      "dist-electron/remote-guard.js",
      "dist-electron/remote-guard-core.js",
      "dist-electron/translation-cache-crypto.js",
      "dist-electron/payment-address.js",
      "dist-electron/sensitive-send-authorization.js",
      "dist-electron/translation-sensitive-tokens.js",
      "dist-electron/translation-prompt-bundle.js",
      "dist-electron/smart-reply-core.js",
      "dist-electron/smart-reply-prompt-bundle.js",
      "dist-electron/translation-english-style.js",
      "dist-electron/shared.js",
      "electron/preload.cjs",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".package-secrets/client-license-suite.json",
        "to": "license-suite-public.json"
      },
      {
        "from": ".package-secrets/translation-prompts.dfp",
        "to": "translation-prompts.dfp"
      },
      {
        "from": ".package-secrets/smart-reply-prompt.dfp",
        "to": "smart-reply-prompt.dfp"
      },
      {
        "from": ".package-staging/signal",
        "to": "signal"
      }
    ],
    "afterPack": "./tools/electron-builder-after-pack.cjs",
    "win": {
      "target": "nsis",
      "artifactName": "maoyi-${version}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "maoyi"
    }
  },
  "dependencies": {
    "@noble/hashes": "2.2.0",
    "@scure/base": "2.2.0"
  }
}
